@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    bool isAuthenticated = User.Identity?.IsAuthenticated ?? false;

    bool isAdmin = User.IsInRole("Super Admin");
    bool isHR = User.IsInRole("HR");
    bool isManager = User.IsInRole("Manager");
    bool isEmployee = User.IsInRole("Employee");

    bool canManageOrganization = isAdmin || isHR || isManager;
    bool canManageWorkforce = isAdmin || isHR || isManager;
    bool canManageAdministration = isAdmin;
}

<nav class="ems-navbar">

    <div class="ems-nav-container">

        <!-- ======================================
                LOGO
        ======================================= -->

        <a class="ems-brand"
           asp-controller="Home"
           asp-action="Index">

            <div class="ems-logo">

                <i class="bi bi-buildings-fill"></i>

            </div>

            <div class="ems-brand-text">

                <h3>
                    Employee Management System
                </h3>

                <span>
                    Manage Your Workforce Efficiently
                </span>

            </div>

        </a>

        <!-- ======================================
                MOBILE TOGGLE
        ======================================= -->

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#emsNavbar"
                aria-controls="emsNavbar"
                aria-expanded="false">

            <i class="bi bi-list"></i>

        </button>

        <div class="collapse navbar-collapse"
             id="emsNavbar">

            <!-- ======================================
                    LEFT MENU
            ======================================= -->

            <ul class="ems-menu">

                <!-- HOME -->

                <li>

                    <a class="@(currentController == "Home" && currentAction == "Index" ? "active" : "")"
                       asp-controller="Home"
                       asp-action="Index">

                        <i class="bi bi-house-door-fill"></i>

                        Home

                    </a>

                </li>

                @if (isAuthenticated)
                {

                    <!-- DASHBOARD -->

                    <li>

                        <a class="@(currentController == "Dashboard" ? "active" : "")"
                           asp-controller="Dashboard"
                           asp-action="Index">

                            <i class="bi bi-speedometer2"></i>

                            Dashboard

                        </a>

                    </li>
                    <!-- ======================================
                            ORGANIZATION
                    ======================================= -->
                    @if (canManageOrganization)
                    {
                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle
                                @(currentController == "Branch" ||
                                 currentController == "Department" ||
                                 currentController == "Designation" ||
                                 currentController == "Role"
                                    ? "active" : "")"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">

                                <i class="bi bi-diagram-3-fill"></i>

                                Organization

                            </a>

                            <ul class="dropdown-menu shadow">

                                <li>

                                    <a class="dropdown-item @(currentController == "Branch" ? "active" : "")"
                                       asp-controller="Branch"
                                       asp-action="Index">

                                        <i class="bi bi-building"></i>

                                        Branches

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item @(currentController == "Department" ? "active" : "")"
                                       asp-controller="Department"
                                       asp-action="Index">

                                        <i class="bi bi-diagram-2"></i>

                                        Departments

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item @(currentController == "Designation" ? "active" : "")"
                                       asp-controller="Designation"
                                       asp-action="Index">

                                        <i class="bi bi-person-badge"></i>

                                        Designations

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item @(currentController == "Role" ? "active" : "")"
                                       asp-controller="Role"
                                       asp-action="Index">

                                        <i class="bi bi-shield-lock"></i>

                                        Roles

                                    </a>

                                </li>

                            </ul>

                        </li>
                    }
                    <!-- ======================================
                            WORKFORCE
                    ======================================= -->
                    @if (canManageWorkforce)
                    {
                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle
                                @(currentController == "Employee" ||
                                 currentController == "Attendance" ||
                                 currentController == "Leave" ||
                                 currentController == "Payroll"
                                    ? "active" : "")"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">

                                <i class="bi bi-people-fill"></i>

                                Workforce

                            </a>

                            <ul class="dropdown-menu shadow">

                                <li>

                                    <a class="dropdown-item @(currentController == "Employee" ? "active" : "")"
                                       asp-controller="Employee"
                                       asp-action="Index">

                                        <i class="bi bi-person-lines-fill"></i>

                                        Employees

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item disabled">

                                        <i class="bi bi-calendar-check"></i>

                                        Attendance (Coming Soon)

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item disabled">

                                        <i class="bi bi-calendar-heart"></i>

                                        Leave Management (Coming Soon)

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item disabled">

                                        <i class="bi bi-cash-stack"></i>

                                        Payroll (Coming Soon)

                                    </a>

                                </li>

                            </ul>

                        </li>
                    }

                    <!-- ======================================
                            REPORTS
                    ======================================= -->
                    @if (canManageWorkforce)
                    {
                        <li>

                            <a class="@(currentController == "Reports" ? "active" : "")"
                               asp-controller="Reports"
                               asp-action="Index">

                                <i class="bi bi-bar-chart-fill"></i>

                                Reports

                            </a>

                        </li>
                    }

                    <!-- ======================================
                            SECURITY & ADMINISTRATION
                    ======================================= -->
                    @if (canManageAdministration)
                    {
                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle
                                @(currentController == "User" ||
                                 currentController == "ActivityLog"
                                    ? "active" : "")"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">

                                <i class="bi bi-shield-lock-fill"></i>

                                Administration

                            </a>

                            <ul class="dropdown-menu shadow">

                                <li>

                                    <a class="dropdown-item @(currentController == "User" ? "active" : "")"
                                       asp-controller="User"
                                       asp-action="Index">

                                        <i class="bi bi-people-fill"></i>

                                        Users

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item @(currentController == "ActivityLog" ? "active" : "")"
                                       asp-controller="ActivityLog"
                                       asp-action="Index">

                                        <i class="bi bi-clock-history"></i>

                                        Activity Logs

                                    </a>

                                </li>
                                <li>
                                    <a asp-controller="Permission"
                                       asp-action="Index"
                                       class="dropdown-item">

                                        🔑 Permissions

                                    </a>
                                </li>
                                <li>
                                    <a asp-controller="RolePermission"
                                       asp-action="Index"
                                       class="dropdown-item">

                                        🔐 Role Permissions

                                    </a>
                                </li>

                            </ul>

                        </li>
                    }
                }
                else
                {
                    <!-- ======================================
                            PUBLIC MENU
                    ======================================= -->

                    <li>

                        <a class="@(currentAction == "Features" ? "active" : "")"
                           asp-controller="Home"
                           asp-action="Features">

                            <i class="bi bi-stars"></i>

                            Features

                        </a>

                    </li>

                    <li>

                        <a class="@(currentAction == "About" ? "active" : "")"
                           asp-controller="Home"
                           asp-action="About">

                            <i class="bi bi-info-circle"></i>

                            About Us

                        </a>

                    </li>
                }

            </ul>

            <!-- ======================================
                    RIGHT MENU
            ======================================= -->

            <ul class="ems-right-menu">

                @if (isAuthenticated)
                {
                    <!-- NOTIFICATION -->

                    <li class="ems-notification">

                        <a href="#">

                            <i class="bi bi-bell-fill"></i>

                            <span>3</span>

                        </a>

                    </li>

                    <!-- PROFILE -->

                    <li class="dropdown">

                        <a class="ems-profile dropdown-toggle"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">

                            <div class="ems-avatar">

                                <i class="bi bi-person-fill"></i>

                            </div>

                            <div class="ems-user-info">

                                <strong>

                                    @User.Identity?.Name

                                </strong>

                                <small>

                                    @(isAdmin ? "Administrator"
                                        : isHR ? "HR"
                                        : isManager ? "Manager"
                                        : isEmployee ? "Employee"
                                        : "User")

                                </small>

                            </div>

                        </a>

                        <ul class="dropdown-menu dropdown-menu-end shadow">

                            <li>

                                <a class="dropdown-item"
                                   asp-controller="Profile"
                                   asp-action="Index">

                                    <i class="bi bi-person-circle"></i>

                                    My Profile

                                </a>

                            </li>

                            <li>

                                <a class="dropdown-item"
                                   asp-controller="Account"
                                   asp-action="ChangePassword">

                                    <i class="bi bi-key"></i>

                                    Change Password

                                </a>

                            </li>

                            <li>

                                <hr class="dropdown-divider" />

                            </li>

                            <li>

                                <a class="dropdown-item text-danger"
                                   asp-controller="Account"
                                   asp-action="Logout">

                                    <i class="bi bi-box-arrow-right"></i>

                                    Logout

                                </a>

                            </li>

                        </ul>

                    </li>

                }
                else
                {
                    <li>

                        <a class="ems-login-btn"
                           asp-controller="Account"
                           asp-action="Login">

                            <i class="bi bi-box-arrow-in-right"></i>

                            Login

                        </a>

                    </li>
                }

            </ul>

        </div>

    </div>

</nav>