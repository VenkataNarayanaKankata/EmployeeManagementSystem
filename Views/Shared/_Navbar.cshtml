@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    bool isAuthenticated = User.Identity?.IsAuthenticated ?? false;

    var permissionService =
     Context.RequestServices.GetRequiredService<IPermissionService>();


    bool canViewDashboard =
        await permissionService.HasPermissionAsync("Dashboard.View");


    bool canViewEmployee =
        await permissionService.HasPermissionAsync("Employee.View");


    bool canViewBranch =
        await permissionService.HasPermissionAsync("Branch.View");


    bool canViewDepartment =
        await permissionService.HasPermissionAsync("Department.View");


    bool canViewDesignation =
        await permissionService.HasPermissionAsync("Designation.View");


    bool canViewReports =
        await permissionService.HasPermissionAsync("Report.View");


    bool canViewUsers =
        await permissionService.HasPermissionAsync("User.View");


    bool canViewActivity =
        await permissionService.HasPermissionAsync("ActivityLog.View");


    bool canManagePermissions =
        await permissionService.HasPermissionAsync("Role.AssignPermission");
    bool canViewPermission =
    await permissionService.HasPermissionAsync("Permission.View");


    bool canViewProfile =
        await permissionService.HasPermissionAsync("Profile.View");

    bool canViewRole =
        await permissionService.HasPermissionAsync("Role.View");
}

<nav class="ems-navbar">

    <div class="ems-nav-container">

        <!-- ======================================
                LOGO
        ======================================= -->

        <a class="ems-brand"
           asp-controller="Home"
           asp-action="Index">

            <div class="ems-logo">

                <i class="bi bi-buildings-fill"></i>

            </div>

            <div class="ems-brand-text">

                <h3>
                    Employee Management System
                </h3>

                <span>
                    Manage Your Workforce Efficiently
                </span>

            </div>

        </a>

        <!-- ======================================
                MOBILE TOGGLE
        ======================================= -->

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#emsNavbar"
                aria-controls="emsNavbar"
                aria-expanded="false">

            <i class="bi bi-list"></i>

        </button>

        <div class="collapse navbar-collapse"
             id="emsNavbar">

            <!-- ======================================
                    LEFT MENU
            ======================================= -->

            <ul class="ems-menu">

                <!-- HOME -->

                <li>

                    <a class="@(currentController == "Home" && currentAction == "Index" ? "active" : "")"
                       asp-controller="Home"
                       asp-action="Index">

                        <i class="bi bi-house-door-fill"></i>

                        Home

                    </a>

                </li>

                @if (canViewDashboard){
                        <li>
                            <a asp-controller="Dashboard"
                               asp-action="Index">

                                <i class="bi bi-speedometer2"></i>

                                Dashboard

                            </a>
                        </li>
                }
                    <!-- ======================================
                            ORGANIZATION
                    ======================================= -->
                @if (canViewBranch ||
 canViewDepartment ||
 canViewDesignation ||
 canViewRole)
 {
                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle
                                @(currentController == "Branch" ||
                                 currentController == "Department" ||
                                 currentController == "Designation" ||
                                 currentController == "Role"
                                    ? "active" : "")"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">

                                <i class="bi bi-diagram-3-fill"></i>

                                Organization

                            </a>

                            <ul class="dropdown-menu shadow">

                                <li>

                                    @if (canViewBranch)
                                    {
                                        <a asp-controller="Branch"
                                           asp-action="Index">

                                            Branches

                                        </a>
                                    }

                                </li>

                                <li>

                                    @if (canViewDepartment)
                                    {
                                        <a asp-controller="Department"
                                           asp-action="Index">

                                            Departments

                                        </a>
                                    }

                                </li>

                                <li>

                                    @if (canViewDesignation)
                                    {
                                        <a asp-controller="Designation"
                                           asp-action="Index">

                                            Designations

                                        </a>
                                    }

                                </li>

                                <li>

                                   @if(canViewRole)
{
    <a class="dropdown-item"
       asp-controller="Role"
       asp-action="Index">

        <i class="bi bi-shield-lock"></i>

        Roles

    </a>
}

                                </li>

                            </ul>

                        </li>
                    }
                    <!-- ======================================
                            WORKFORCE
                    ======================================= -->
                    @if (canViewEmployee)
                    {
                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle
                                @(currentController == "Employee" ||
                                 currentController == "Attendance" ||
                                 currentController == "Leave" ||
                                 currentController == "Payroll"
                                    ? "active" : "")"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">

                                <i class="bi bi-people-fill"></i>

                                Workforce

                            </a>

                            <ul class="dropdown-menu shadow">

                                <li>

                                    @if (canViewEmployee)
                                    {
                                        <a asp-controller="Employee"
                                           asp-action="Index">

                                            Employees

                                        </a>
                                    }

                                </li>

                                <li>

                                    <a class="dropdown-item disabled">

                                        <i class="bi bi-calendar-check"></i>

                                        Attendance (Coming Soon)

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item disabled">

                                        <i class="bi bi-calendar-heart"></i>

                                        Leave Management (Coming Soon)

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item disabled">

                                        <i class="bi bi-cash-stack"></i>

                                        Payroll (Coming Soon)

                                    </a>

                                </li>

                            </ul>

                        </li>
                    }

                    <!-- ======================================
                            REPORTS
                    ======================================= -->
                    @if (canViewReports)
                    {
                        <li>

                        <a class="@(currentController == "Reports" ? "active" : "")"
                           asp-controller="Reports"
                           asp-action="Index">

                                <i class="bi bi-bar-chart-fill"></i>

                                Reports

                            </a>

                        </li>
                    }
                    

                    <!-- ======================================
                            SECURITY & ADMINISTRATION
                    ======================================= -->
                @if (canViewUsers ||
 canViewActivity ||
 canViewPermission ||
 canManagePermissions)
                    {
                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle
                                @(currentController == "User" ||
                                 currentController == "ActivityLog"
                                    ? "active" : "")"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">

                                <i class="bi bi-shield-lock-fill"></i>

                                Administration

                            </a>

                            <ul class="dropdown-menu shadow">

                                <li>

                                    @if (canViewUsers)
                                    {
                                        <a asp-controller="User"
                                           asp-action="Index">

                                            Users

                                        </a>
                                    }

                                </li>

                                <li>

                                    @if (canViewActivity)
                                    {
                                        <a asp-controller="ActivityLog"
                                           asp-action="Index">

                                            Activity Logs

                                        </a>
                                    }

                                </li>
                                <li>
                                    @if(canViewPermission)
{
    <a asp-controller="Permission"
       asp-action="Index"
       class="dropdown-item">

        Permissions

    </a>
}
                                </li>
                                <li>
                                    @if (canManagePermissions)
                                    {
                                        <a asp-controller="RolePermission"
                                           asp-action="Index">

                                            Role Permissions

                                        </a>
                                    }
                                </li>

                            </ul>

                        </li>
                    }
                @if (!isAuthenticated)
                {
                    <li>
                        <a class="@(currentAction == "Features" ? "active" : "")"
                           asp-controller="Home"
                           asp-action="Features">

                            <i class="bi bi-stars"></i>

                            Features

                        </a>
                    </li>


                    <li>
                        <a class="@(currentAction == "About" ? "active" : "")"
                           asp-controller="Home"
                           asp-action="About">

                            <i class="bi bi-info-circle"></i>

                            About Us

                        </a>
                    </li>
                }

            </ul>

            <!-- ======================================
                    RIGHT MENU
            ======================================= -->

            <ul class="ems-right-menu">

                @if (isAuthenticated)
                {
                    <!-- NOTIFICATION -->

                    <li class="ems-notification">

                        <a href="#">

                            <i class="bi bi-bell-fill"></i>

                            <span>3</span>

                        </a>

                    </li>

                    <!-- PROFILE -->

                    <li class="dropdown">

                        <a class="ems-profile dropdown-toggle"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">

                            <div class="ems-avatar">

                                <i class="bi bi-person-fill"></i>

                            </div>

                            <div class="ems-user-info">

                                <strong>

                                    @User.Identity?.Name

                                </strong>

                                <small>

                                    @(
                                        User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                        ?? "User"
                                    )

                                </small>

                            </div>

                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow">

                            <li>
                                @if (canViewProfile)
                                {
                                    <a class="dropdown-item"
                                       asp-controller="Profile"
                                       asp-action="Index">

                                        <i class="bi bi-person-circle me-2"></i>
                                        My Profile

                                    </a>
                                }
                            </li>


                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Account"
                                   asp-action="ChangePassword">

                                    <i class="bi bi-key me-2"></i>
                                    Change Password

                                </a>
                            </li>


                            <li>
                                <hr class="dropdown-divider" />
                            </li>


                            <li>
                                <a class="dropdown-item text-danger"
                                   asp-controller="Account"
                                   asp-action="Logout">

                                    <i class="bi bi-box-arrow-right me-2"></i>
                                    Logout

                                </a>
                            </li>

                        </ul>

                    </li>

                }
                else
                {
                    <li>

                        @if (!User.Identity.IsAuthenticated)
                        {
                            <a asp-controller="Account"
                               asp-action="Login"
                               class="btn btn-primary">

                                Login

                            </a>
                        }

                    </li>
                }

            </ul>

        </div>

    </div>

</nav>