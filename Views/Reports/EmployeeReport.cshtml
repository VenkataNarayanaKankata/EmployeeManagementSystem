@model EmployeeManagementSystem.ViewModels.EmployeeReportViewModel
<nav aria-label="breadcrumb" class="mb-3 no-print">

    <ol class="breadcrumb">

        <li class="breadcrumb-item">

            <a asp-controller="Home"
               asp-action="Index">

                🏠 Home

            </a>

        </li>

        <li class="breadcrumb-item">

            <a asp-controller="Reports"
               asp-action="Index">

                📊 Reports

            </a>

        </li>

        <li class="breadcrumb-item active"
            aria-current="page">

            Employee Report

        </li>

    </ol>

</nav>
@{
    ViewData["Title"] = "Employee Report";
}

<div class="container mt-4">

    <!-- Page Header -->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold text-primary">
                👨‍💼 Employee Report
            </h2>

            <p class="text-muted mb-0">
                Employee statistics and complete employee information.
            </p>

        </div>

        <div class="no-print">

            <a asp-controller="Reports"
               asp-action="Index"
               class="btn btn-secondary me-2">

                ← Back to Reports

            </a>


            @if (await PermissionService.HasPermissionAsync("Report.Print"))
            {
                <button type="button"
                        class="btn btn-success me-2"
                        onclick="window.print();">

                    🖨 Print Report

                </button>
            }


            @if (await PermissionService.HasPermissionAsync("Report.Export"))
            {
                <a asp-controller="Reports"
                   asp-action="ExportEmployeeExcel"
                   class="btn btn-primary">

                    📥 Export Excel

                </a>
            }

        </div>

    </div>

    <!-- Search Filters -->

    <form id="employeeFilterForm"
          asp-action="EmployeeReport"
          method="get"
          class="no-print">

        <div class="card shadow border-0 mb-4">

            <div class="card-header bg-secondary text-white">

                <h5 class="mb-0">

                    🔍 Search Filters

                </h5>

            </div>

            <div class="card-body">

                <div class="row g-3">

                    <!-- Employee Name -->

                    <div class="col-lg-3 col-md-6">

                        <label class="form-label fw-bold">

                            Employee Name

                        </label>

                        <input asp-for="Filter.SearchName"
                               name="searchName"
                               class="form-control"
                               placeholder="Search employee..." />

                    </div>

                    <!-- Department -->

                    <div class="col-lg-3 col-md-6">

                        <label class="form-label fw-bold">

                            Department

                        </label>

                        <select asp-for="Filter.DepartmentId"
                                name="departmentId"
                                asp-items="Model.Departments"
                                class="form-select">

                            <option value="">All Departments</option>

                        </select>

                    </div>

                    <!-- From -->

                    <div class="col-lg-2 col-md-6">

                        <label class="form-label fw-bold">

                            From

                        </label>

                        <input asp-for="Filter.FromDate"
                               name="fromDate"
                               type="date"
                               class="form-control" />

                    </div>

                    <!-- To -->

                    <div class="col-lg-2 col-md-6">

                        <label class="form-label fw-bold">

                            To

                        </label>

                        <input asp-for="Filter.ToDate"
                               name="toDate"
                               type="date"
                               class="form-control" />

                    </div>

                    <!-- Buttons -->

                    <div class="col-lg-2 col-md-12 d-flex align-items-end">

                        <button type="submit"
                                class="btn btn-primary me-2">

                            🔍 Search

                        </button>

                        <a asp-action="EmployeeReport"
                           class="btn btn-secondary">

                            Clear

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </form>

    <!-- Employee Table -->
    <div id="reportContent"
         class="print-content">

        <partial name="_EmployeeReportContent" model="Model" />

    </div>
    

</div>
@section Scripts
{
    @if (ViewBag.Print == true)
    {
        <script>

                        window.addEventListener("load", function () {

                setTimeout(function () {

                    window.print();

                }, 800);

            });

        </script>
    }
    <script>

        setupAjaxFilter("employeeFilterForm", "reportContent");

    </script>
}