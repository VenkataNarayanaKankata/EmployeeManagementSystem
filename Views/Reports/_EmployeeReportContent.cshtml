@model EmployeeManagementSystem.ViewModels.EmployeeReportViewModel

<!-- Summary Cards -->

<div class="row g-4 mb-4">

    <div class="col-md-3">

        <div class="card shadow border-0">

            <div class="card-body text-center">

                <h6 class="text-muted">

                    Total Employees

                </h6>

                <h2 class="text-primary">

                    @Model.TotalEmployees

                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-3">

        <div class="card shadow border-0">

            <div class="card-body text-center">

                <h6 class="text-muted">

                    Average Salary

                </h6>

                <h2 class="text-success">

                    ₹ @Model.AverageSalary.ToString("N0")

                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-3">

        <div class="card shadow border-0">

            <div class="card-body text-center">

                <h6 class="text-muted">

                    Highest Salary

                </h6>

                <h2 class="text-warning">

                    ₹ @Model.HighestSalary.ToString("N0")

                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-3">

        <div class="card shadow border-0">

            <div class="card-body text-center">

                <h6 class="text-muted">

                    Lowest Salary

                </h6>

                <h2 class="text-danger">

                    ₹ @Model.LowestSalary.ToString("N0")

                </h2>

            </div>

        </div>

    </div>

</div>
<div class="card shadow border-0">

    <div class="card-header bg-primary text-white">

        <h5 class="mb-0">

            Employee Information

        </h5>

    </div>

    <div class="table-responsive">

        <table class="table table-hover table-striped mb-0">

            <thead class="table-light">

                <tr>

                    <th>#</th>
                    <th>Name</th>
                    <th>Department</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Salary</th>
                    <th>Joining Date</th>

                </tr>

            </thead>

            <tbody>

                @if (Model.Employees.Any())
                {
                    int count = 1;

                    @foreach (var employee in Model.Employees)
                    {
                        <tr>

                            <td>@count</td>

                            <td>
                                @employee.FirstName @employee.LastName
                            </td>

                            <td>
                                @employee.Department?.DepartmentName
                            </td>

                            <td>
                                @employee.Email
                            </td>

                            <td>
                                @employee.Phone
                            </td>

                            <td class="fw-bold text-success">
                                ₹ @employee.Salary.ToString("N0")
                            </td>

                            <td>
                                @employee.JoiningDate.ToString("dd-MMM-yyyy")
                            </td>

                        </tr>

                        count++;
                    }
                }
                else
                {
                    <tr>

                        <td colspan="7" class="text-center py-5">

                            <partial name="_NoRecordsFound" />

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>
