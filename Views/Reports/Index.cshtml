@inject EmployeeManagementSystem.Services.IPermissionService PermissionService

@{
    ViewData["Title"] = "Reports Dashboard";
}

<div class="container mt-4">

    <div class="mb-4">

        <h2 class="fw-bold text-primary">
            📊 Reports Dashboard
        </h2>

        <p class="text-muted">
            Generate and export various reports from the Employee Management System.
        </p>

    </div>


    <div class="row g-4">


        @if (await PermissionService.HasPermissionAsync("Report.Employee"))
        {

            <div class="col-md-6 col-lg-4">

                <div class="card shadow h-100 border-0">

                    <div class="card-body text-center">

                        <div style="font-size:60px;">
                            👨‍💼
                        </div>


                        <h4 class="mt-3">
                            Employee Report
                        </h4>


                        <p class="text-muted">
                            View employee information and export reports.
                        </p>


                        <hr />


                        <div class="d-flex justify-content-center gap-2">


                            <a asp-controller="Reports"
                               asp-action="EmployeeReport"
                               class="btn btn-primary">

                                View Report

                            </a>



                            @if (await PermissionService.HasPermissionAsync("Report.Print"))
                            {

                                <a asp-controller="Reports"
                                   asp-action="EmployeeReport"
                                   asp-route-print="true"
                                   class="btn btn-outline-primary">

                                    🖨 Print

                                </a>

                            }



                            @if (await PermissionService.HasPermissionAsync("Report.Export"))
                            {

                                <a asp-controller="Reports"
                                   asp-action="ExportEmployeeExcel"
                                   class="btn btn-success">

                                    Excel

                                </a>

                            }


                        </div>


                    </div>

                </div>

            </div>

        }





        @if (await PermissionService.HasPermissionAsync("Report.Department"))
        {

            <div class="col-md-6 col-lg-4">

                <div class="card shadow h-100 border-0">


                    <div class="card-body text-center">


                        <div style="font-size:60px;">
                            🏢
                        </div>


                        <h4 class="mt-3">
                            Department Report
                        </h4>


                        <p class="text-muted">
                            Department-wise employee information.
                        </p>


                        <hr />



                        <div class="d-flex justify-content-center gap-2">


                            <a asp-controller="Reports"
                               asp-action="DepartmentReport"
                               class="btn btn-success">

                                View Report

                            </a>



                            @if (await PermissionService.HasPermissionAsync("Report.Print"))
                            {

                                <a asp-controller="Reports"
                                   asp-action="DepartmentReport"
                                   asp-route-print="true"
                                   class="btn btn-outline-success">

                                    🖨 Print

                                </a>

                            }



                            @if (await PermissionService.HasPermissionAsync("Report.Export"))
                            {

                                <a asp-controller="Reports"
                                   asp-action="ExportDepartmentExcel"
                                   class="btn btn-success">

                                    Excel

                                </a>

                            }


                        </div>


                    </div>

                </div>

            </div>

        }







        @if (await PermissionService.HasPermissionAsync("Report.Salary"))
        {


            <div class="col-md-6 col-lg-4">


                <div class="card shadow h-100 border-0">


                    <div class="card-body text-center">


                        <div style="font-size:60px;">
                            💰
                        </div>



                        <h4 class="mt-3">
                            Salary Report
                        </h4>



                        <p class="text-muted">
                            Salary analysis and statistics.
                        </p>


                        <hr />



                        <div class="d-flex justify-content-center gap-2">


                            <a asp-controller="Reports"
                               asp-action="SalaryReport"
                               class="btn btn-warning">

                                View Report

                            </a>



                            @if (await PermissionService.HasPermissionAsync("Report.Print"))
                            {

                                <a asp-controller="Reports"
                                   asp-action="SalaryReport"
                                   asp-route-print="true"
                                   class="btn btn-outline-warning">

                                    🖨 Print

                                </a>

                            }



                            @if (await PermissionService.HasPermissionAsync("Report.Export"))
                            {

                                <a asp-controller="Reports"
                                   asp-action="ExportSalaryExcel"
                                   class="btn btn-success">

                                    Excel

                                </a>

                            }


                        </div>


                    </div>


                </div>


            </div>

        }







        @if (await PermissionService.HasPermissionAsync("Report.Joining"))
        {


            <div class="col-md-6 col-lg-4">


                <div class="card shadow h-100 border-0">


                    <div class="card-body text-center">


                        <div style="font-size:60px;">
                            📅
                        </div>



                        <h4 class="mt-3">
                            Joining Report
                        </h4>



                        <p class="text-muted">
                            Employee joining statistics.
                        </p>



                        <hr />



                        <div class="d-flex justify-content-center gap-2">


                            <a asp-controller="Reports"
                               asp-action="JoiningReport"
                               class="btn btn-secondary">

                                View Report

                            </a>



                            @if (await PermissionService.HasPermissionAsync("Report.Print"))
                            {

                                <a asp-controller="Reports"
                                   asp-action="JoiningReport"
                                   asp-route-print="true"
                                   class="btn btn-outline-secondary">

                                    🖨 Print

                                </a>

                            }



                            @if (await PermissionService.HasPermissionAsync("Report.Export"))
                            {

                                <a asp-controller="Reports"
                                   asp-action="ExportJoiningExcel"
                                   class="btn btn-success">

                                    Excel

                                </a>

                            }


                        </div>


                    </div>


                </div>


            </div>

        }






        @if (await PermissionService.HasPermissionAsync("ActivityLog.View"))
        {

            <div class="col-md-6 col-lg-4">


                <div class="card shadow h-100 border-0">


                    <div class="card-body text-center">


                        <div style="font-size:60px;">
                            📜
                        </div>


                        <h4 class="mt-3">
                            Activity Report
                        </h4>


                        <p class="text-muted">
                            Administrator activity history.
                        </p>


                        <hr />


                        <a asp-controller="ActivityLog"
                           asp-action="Index"
                           class="btn btn-dark">

                            View Report

                        </a>


                        @if (await PermissionService.HasPermissionAsync("ActivityLog.Print"))
                        {
                            <a asp-controller="ActivityLog"
                               asp-action="Index"
                               asp-route-print="true"
                               class="btn btn-outline-dark">

                                🖨 Print

                            </a>
                        }


                        @if (await PermissionService.HasPermissionAsync("ActivityLog.Export"))
                        {
                            <a asp-controller="ActivityLog"
                               asp-action="Export"
                               class="btn btn-success">

                                Excel

                            </a>
                        }

                    </div>


                </div>


            </div>

        }




    </div>


</div>