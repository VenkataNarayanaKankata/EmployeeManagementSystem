@{
    ViewData["Title"] = "Reports Dashboard";
}

<div class="container mt-4">

    <div class="mb-4">
        <h2 class="fw-bold text-primary">
            📊 Reports Dashboard
        </h2>

        <p class="text-muted">
            Generate and export various reports from the Employee Management System.
        </p>
    </div>

    <div class="row g-4">

        <!-- Employee Report -->
        <div class="col-md-6 col-lg-4">

            <div class="card shadow h-100 border-0">

                <div class="card-body text-center">

                    <div style="font-size:60px;">👨‍💼</div>

                    <h4 class="mt-3">
                        Employee Report
                    </h4>

                    <p class="text-muted">
                        View employee information and export reports.
                    </p>

                    <hr />

                    <div class="d-flex justify-content-center gap-2">

                        <a asp-controller="Reports"
                           asp-action="EmployeeReport"
                           class="btn btn-primary">

                            View Report

                        </a>

                        <a asp-controller="Reports"
                           asp-action="EmployeeReport"
                           asp-route-print="true"
                           class="btn btn-outline-primary">

                            🖨 Print

                        </a>

                    </div>

                </div>

            </div>

        </div>

        <!-- Department Report -->
        <div class="col-md-6 col-lg-4">

            <div class="card shadow h-100 border-0">

                <div class="card-body text-center">

                    <div style="font-size:60px;">🏢</div>

                    <h4 class="mt-3">
                        Department Report
                    </h4>

                    <p class="text-muted">
                        Department-wise employee information.
                    </p>

                    <hr />

                    <div class="d-flex justify-content-center gap-2">

                        <a asp-controller="Reports"
                           asp-action="DepartmentReport"
                           class="btn btn-success">

                            View Report

                        </a>

                        <a asp-controller="Reports"
                           asp-action="DepartmentReport"
                           asp-route-print="true"
                           class="btn btn-outline-success">

                            🖨 Print

                        </a>

                    </div>

                </div>

            </div>

        </div>

        <!-- Salary Report -->
        <div class="col-md-6 col-lg-4">

            <div class="card shadow h-100 border-0">

                <div class="card-body text-center">

                    <div style="font-size:60px;">💰</div>

                    <h4 class="mt-3">
                        Salary Report
                    </h4>

                    <p class="text-muted">
                        Salary analysis and statistics.
                    </p>

                    <hr />
                    <div class="d-flex justify-content-center gap-2">

                        <a asp-controller="Reports"
                           asp-action="SalaryReport"
                           class="btn btn-warning">

                            View Report

                        </a>

                        <a asp-controller="Reports"
                           asp-action="SalaryReport"
                           asp-route-print="true"
                           class="btn btn-outline-warning">

                            🖨 Print

                        </a>

                    </div>

                </div>

            </div>

        </div>

        <!-- Activity Report -->
        <div class="col-md-6 col-lg-4">

            <div class="card shadow h-100 border-0">

                <div class="card-body text-center">

                    <div style="font-size:60px;">📜</div>

                    <h4 class="mt-3">
                        Activity Report
                    </h4>

                    <p class="text-muted">
                        Print all administrator activities.
                    </p>

                    <hr />

                    <div class="d-flex justify-content-center gap-2">

                        <a asp-controller="ActivityLog"
                           asp-action="Index"
                           class="btn btn-dark">

                            View Report

                        </a>

                        <a asp-controller="ActivityLog"
                           asp-action="Index"
                           asp-route-print="true"
                           class="btn btn-outline-dark">

                            🖨 Print

                        </a>

                    </div>

                </div>

            </div>

        </div>

        <!-- Joining Report -->
        <div class="col-md-6 col-lg-4">

            <div class="card shadow h-100 border-0">

                <div class="card-body text-center">

                    <div style="font-size:60px;">📅</div>

                    <h4 class="mt-3">
                        Joining Report
                    </h4>

                    <p class="text-muted">
                        Employee joining statistics.
                    </p>

                    <hr />

                    <div class="d-flex justify-content-center gap-2">

                        <a asp-controller="Reports"
                           asp-action="JoiningReport"
                           class="btn btn-secondary">

                            View Report

                        </a>

                        <a asp-controller="Reports"
                           asp-action="JoiningReport"
                           asp-route-print="true"
                           class="btn btn-outline-secondary">

                            🖨 Print

                        </a>

                    </div>

                </div>

            </div>

        </div>

        <!-- Dashboard Summary -->
        <div class="col-md-6 col-lg-4">

            <div class="card shadow h-100 border-0 bg-primary text-white">

                <div class="card-body text-center">

                    <div style="font-size:60px;">📈</div>

                    <h4 class="mt-3">
                        Reports Summary
                    </h4>

                    <p>
                        Access all reports from one place.
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>