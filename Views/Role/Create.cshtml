@model EmployeeManagementSystem.Models.Role

@{
    ViewData["Title"] = "Create Role";
}
@if(await PermissionService.HasPermissionAsync("Role.Create"))
{

<div class="container mt-4">


    <div class="employee-header mb-4">

        <div class="employee-header-left">

            <h1>
                🔐 Create New Role
            </h1>

            <p>
                Add a new system role for employee access management.
            </p>

        </div>

    </div>



    <div class="card shadow-lg border-0 rounded-4">


        <div class="card-header bg-primary text-white">

            <h3 class="mb-0">
                ➕ Role Information
            </h3>

        </div>



        <div class="card-body p-4">


            <form asp-action="Create">


                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3"></div>



                <div class="row g-4">


                    <div class="col-md-6">


                        <label asp-for="RoleName"
                               class="form-label fw-semibold">

                            Role Name

                        </label>


                        <input asp-for="RoleName"
                               class="form-control"
                               placeholder="Enter role name" />


                        <span asp-validation-for="RoleName"
                              class="text-danger"></span>


                    </div>





                    <div class="col-md-6">


                        <label asp-for="IsActive"
                               class="form-label fw-semibold">

                            Status

                        </label>


                        <select asp-for="IsActive"
                                class="form-select">


                            <option value="true">
                                Active
                            </option>


                            <option value="false">
                                Inactive
                            </option>


                        </select>


                    </div>





                    <div class="col-12">


                        <label asp-for="Description"
                               class="form-label fw-semibold">

                            Description

                        </label>


                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Enter role description"></textarea>


                        <span asp-validation-for="Description"
                              class="text-danger"></span>


                    </div>


                </div>




                <div class="mt-5 d-flex justify-content-end">


                    <a asp-action="Index"
                       class="btn btn-secondary me-3">

                        ← Back

                    </a>



                    <button type="submit"
                            class="btn btn-primary">

                        💾 Save Role

                    </button>


                </div>



            </form>


        </div>


    </div>


</div>
}
else
{
    <div class="alert alert-danger">
        You don't have permission to create roles.
    </div>
}


@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}