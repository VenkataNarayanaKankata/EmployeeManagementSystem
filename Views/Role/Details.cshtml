@model EmployeeManagementSystem.Models.Role

@{
    ViewData["Title"] = "Role Details";
}

@if(await PermissionService.HasPermissionAsync("Role.View"))
{
<div class="container mt-4">


    <div class="employee-header mb-4">


        <div class="employee-header-left">


            <h1>
                🔐 Role Details
            </h1>


            <p>
                View role information and assigned employees.
            </p>


        </div>


    </div>





    <div class="card shadow-lg border-0 rounded-4">


        <div class="card-header bg-primary text-white">

            <h3 class="mb-0">

                @Model.RoleName

            </h3>


        </div>




        <div class="card-body p-4">


            <div class="row g-4">


                <div class="col-md-6">


                    <div class="p-3 border rounded">


                        <label class="text-muted">
                            Role Name
                        </label>


                        <h5 class="fw-bold">

                            @Model.RoleName

                        </h5>


                    </div>


                </div>





                <div class="col-md-6">


                    <div class="p-3 border rounded">


                        <label class="text-muted">
                            Status
                        </label>


                        <h5>


                            @if (Model.IsActive)
                            {

                                <span class="badge bg-success">

                                    Active

                                </span>

                            }
                            else
                            {

                                <span class="badge bg-danger">

                                    Inactive

                                </span>

                            }


                        </h5>


                    </div>


                </div>





                <div class="col-12">


                    <div class="p-3 border rounded">


                        <label class="text-muted">

                            Description

                        </label>


                        <h5>

                            @(string.IsNullOrEmpty(Model.Description)
                            ? "No description available"
                            : Model.Description)

                        </h5>


                    </div>


                </div>



            </div>





            <hr class="my-4" />





            <div class="d-flex justify-content-between align-items-center mb-3">


                <h3 class="fw-bold text-primary">

                    👥 Assigned Employees

                </h3>



                <span class="badge bg-primary fs-6">

                    Total:
                    @(Model.Employees?.Count ?? 0)

                </span>


            </div>





            @if (Model.Employees != null && Model.Employees.Any())
            {


                <div class="table-responsive">


                    <table class="table table-bordered table-striped">


                        <thead class="table-primary">


                            <tr>

                                <th>
                                    Employee Code
                                </th>


                                <th>
                                    Name
                                </th>


                                <th>
                                    Email
                                </th>


                                <th>
                                    Phone
                                </th>


                            </tr>


                        </thead>



                        <tbody>


                            @foreach (var employee in Model.Employees)
                            {


                                <tr>


                                    <td>

                                        @employee.EmployeeCode

                                    </td>



                                    <td>

                                        @employee.FirstName @employee.LastName

                                    </td>



                                    <td>

                                        @employee.Email

                                    </td>



                                    <td>

                                        @employee.Phone

                                    </td>


                                </tr>


                            }


                        </tbody>


                    </table>


                </div>


            }
            else
            {


                <div class="alert alert-info">

                    No employees assigned to this role.

                </div>


            }





            <div class="mt-4">


                    @if (await PermissionService.HasPermissionAsync("Role.Edit"))
                    {
                        <a asp-action="Edit"
                           asp-route-id="@Model.RoleId"
                           class="btn btn-warning">

                            ✏ Edit Role

                        </a>
                    }


                <a asp-action="Index"
                   class="btn btn-secondary ms-2">


                    ← Back


                </a>


            </div>




        </div>


    </div>


</div>
}
else
{
    <div class="alert alert-danger">
        You don't have permission to view role details.
    </div>
}