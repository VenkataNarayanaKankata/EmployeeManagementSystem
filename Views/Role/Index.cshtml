@model EmployeeManagementSystem.ViewModels.RoleViewModel

@{
    ViewData["Title"] = "Roles Management";
}
@if(await PermissionService.HasPermissionAsync("Role.View"))
{

<div class="container mt-4">


    <div class="employee-header mb-4">

        <div class="employee-header-left">

            <h1>
                🔐 Roles Management
            </h1>

            <p>
                Manage system roles, permissions and employee role assignments.
            </p>

        </div>


        <div class="employee-header-right">

                @if (await PermissionService.HasPermissionAsync("Role.Create"))
                {
                    <a asp-action="Create"
                       class="btn btn-primary">

                        ➕ Add Role

                    </a>
                }

        </div>


    </div>



    <div class="row g-4 mb-4">


        <div class="col-md-4">

            <div class="card shadow-sm border-0">

                <div class="card-body">

                    <h6 class="text-muted">
                        Total Roles
                    </h6>

                    <h2 class="fw-bold text-primary">
                        @Model.TotalRoles
                    </h2>

                </div>

            </div>

        </div>



        <div class="col-md-4">

            <div class="card shadow-sm border-0">

                <div class="card-body">

                    <h6 class="text-muted">
                        Active Roles
                    </h6>

                    <h2 class="fw-bold text-success">
                        @Model.ActiveRoles
                    </h2>

                </div>

            </div>

        </div>



        <div class="col-md-4">

            <div class="card shadow-sm border-0">

                <div class="card-body">

                    <h6 class="text-muted">
                        Inactive Roles
                    </h6>

                    <h2 class="fw-bold text-danger">
                        @Model.InactiveRoles
                    </h2>

                </div>

            </div>

        </div>


    </div>




    <div class="card shadow-sm border-0">


        <div class="card-header bg-primary text-white">

            <h5 class="mb-0">
                🔍 Search Roles
            </h5>

        </div>



        <div class="card-body">


            <form method="get"
                  asp-action="Index">


                <div class="row g-3 align-items-end">


                    <div class="col-md-8">


                        <label class="form-label">
                            Role Name
                        </label>


                        <input type="text"
                               name="search"
                               value="@Model.Search"
                               class="form-control"
                               placeholder="Search Role..." />


                    </div>


                    <div class="col-md-4">


                        <button class="btn btn-primary">
                            🔍 Search
                        </button>


                        <a asp-action="Index"
                           class="btn btn-secondary ms-2">
                            🔄 Reset
                        </a>


                    </div>


                </div>


            </form>


        </div>


    </div>





    <div class="card shadow-sm border-0 mt-4">


        <div class="card-header bg-white">


            <h4 class="fw-bold text-primary mb-0">

                👥 Role List

            </h4>


        </div>




        <div class="table-responsive">


            <table class="table table-bordered table-striped align-middle mb-0">


                <thead class="table-primary">

                    <tr>

                        <th>
                            Role Name
                        </th>


                        <th>
                            Description
                        </th>


                        <th>
                            Employees
                        </th>


                        <th>
                            Status
                        </th>


                        <th width="250">
                            Actions
                        </th>

                    </tr>

                </thead>



                <tbody>


                    @if (Model.Roles.Any())
                    {


                        foreach (var item in Model.Roles)
                        {


                            <tr>


                                <td class="fw-bold">

                                    @item.RoleName

                                </td>



                                <td>

                                    @item.Description

                                </td>



                                <td>


                                    <span class="badge bg-primary">

                                        @item.Employees.Count Employee(s)

                                    </span>


                                </td>



                                <td>


                                    @if (item.IsActive)
                                    {

                                        <span class="badge bg-success">
                                            Active
                                        </span>

                                    }
                                    else
                                    {

                                        <span class="badge bg-danger">
                                            Inactive
                                        </span>

                                    }


                                </td>



                                <td>


                                        @if (await PermissionService.HasPermissionAsync("Role.View"))
                                        {
                                            <a asp-action="Details"
                                               asp-route-id="@item.RoleId"
                                               class="btn btn-info btn-sm text-white">

                                                Details

                                            </a>
                                        }


                                        @if (await PermissionService.HasPermissionAsync("Role.Edit"))
                                        {
                                            <a asp-action="Edit"
                                               asp-route-id="@item.RoleId"
                                               class="btn btn-warning btn-sm">

                                                Edit

                                            </a>
                                        }


                                        @if (await PermissionService.HasPermissionAsync("Role.Delete"))
                                        {
                                            <a asp-action="Delete"
                                               asp-route-id="@item.RoleId"
                                               class="btn btn-danger btn-sm">

                                                Delete

                                            </a>
                                        }


                                </td>


                            </tr>

                        }


                    }
                    else
                    {

                        <tr>

                            <td colspan="5"
                                class="text-center py-4">


                                <h5 class="text-muted">

                                    No Roles Found

                                </h5>


                            </td>

                        </tr>

                    }


                </tbody>


            </table>


        </div>


    </div>



</div>
}
else
{
    <div class="alert alert-danger">
        You don't have permission to view roles.
    </div>
}