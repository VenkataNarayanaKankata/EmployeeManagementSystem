@model EmployeeManagementSystem.Models.Role

@{
    ViewData["Title"] = "Delete Role";
}


<div class="container mt-4">


    <div class="employee-header mb-4">


        <div class="employee-header-left">


            <h1 class="text-danger">

                🗑 Delete Role

            </h1>


            <p>

                Remove role after checking employee assignments.

            </p>


        </div>


    </div>





    <div class="card shadow-lg border-0 rounded-4">


        <div class="card-header bg-danger text-white">


            <h3 class="mb-0">

                ⚠ Role Delete Confirmation

            </h3>


        </div>




        <div class="card-body p-4">



            <div class="alert alert-warning">


                <strong>
                    Warning!
                </strong>


                Deleting this role can affect employee access.

                Please make sure no employees are assigned to this role.


            </div>





            <div class="row g-4">


                <div class="col-md-6">


                    <div class="border rounded p-3">


                        <label class="text-muted">

                            Role Name

                        </label>


                        <h4 class="fw-bold">

                            @Model.RoleName

                        </h4>


                    </div>


                </div>





                <div class="col-md-6">


                    <div class="border rounded p-3">


                        <label class="text-muted">

                            Status

                        </label>


                        <h4>


                            @if (Model.IsActive)
                            {

                                <span class="badge bg-success">

                                    Active

                                </span>

                            }
                            else
                            {

                                <span class="badge bg-danger">

                                    Inactive

                                </span>

                            }


                        </h4>


                    </div>


                </div>





                <div class="col-12">


                    <div class="border rounded p-3">


                        <label class="text-muted">

                            Assigned Employees

                        </label>


                        <h4 class="fw-bold text-primary">


                            @(Model.Employees?.Count ?? 0)


                        </h4>


                    </div>


                </div>


            </div>






            <hr class="my-4" />





            <form asp-action="Delete">


                <input type="hidden"
                       asp-for="RoleId" />



                <a asp-action="Index"
                   class="btn btn-secondary">


                    ← Cancel


                </a>




                <button type="submit"
                        class="btn btn-danger ms-2"
                        onclick="return confirm('Are you sure you want to delete this role?');">


                    🗑 Delete Role


                </button>



            </form>



        </div>


    </div>


</div>