@model EmployeeManagementSystem.Models.Role

@{
    ViewData["Title"] = "Edit Role";
}


<div class="container mt-4">


    <div class="employee-header mb-4">

        <div class="employee-header-left">

            <h1>
                ✏️ Edit Role
            </h1>

            <p>
                Update role details and manage role status.
            </p>

        </div>

    </div>




    <div class="card shadow-lg border-0 rounded-4">


        <div class="card-header bg-warning">

            <h3 class="mb-0">
                🔐 Role Information
            </h3>

        </div>



        <div class="card-body p-4">


            <form asp-action="Edit">


                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3"></div>



                <input type="hidden"
                       asp-for="RoleId" />



                <div class="row g-4">



                    <div class="col-md-6">


                        <label asp-for="RoleName"
                               class="form-label fw-semibold">

                            Role Name

                        </label>


                        <input asp-for="RoleName"
                               class="form-control" />


                        <span asp-validation-for="RoleName"
                              class="text-danger"></span>


                    </div>





                    <div class="col-md-6">


                        <label asp-for="IsActive"
                               class="form-label fw-semibold">

                            Status

                        </label>


                        <select asp-for="IsActive"
                                class="form-select">


                            <option value="true">
                                Active
                            </option>


                            <option value="false">
                                Inactive
                            </option>


                        </select>


                    </div>





                    <div class="col-12">


                        <label asp-for="Description"
                               class="form-label fw-semibold">

                            Description

                        </label>


                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="4"></textarea>


                        <span asp-validation-for="Description"
                              class="text-danger"></span>


                    </div>


                </div>




                <div class="mt-5 d-flex justify-content-end">


                    <a asp-action="Index"
                       class="btn btn-secondary me-3">

                        ← Back

                    </a>



                    <button type="submit"
                            class="btn btn-success">

                        💾 Save Changes

                    </button>


                </div>



            </form>


        </div>


    </div>


</div>



@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}