@model EmployeeManagementSystem.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}


@if (await PermissionService.HasPermissionAsync("Profile.View"))
{

    <div class="container mt-4">

        <h5>
            Current RoleId:
            @User.FindFirst("RoleId")?.Value
        </h5>
        <div class="employee-header mb-4">

            <div class="employee-header-left">

                <h1>
                    👤 My Profile
                </h1>

                <p>
                    View your account information and personal details.
                </p>

            </div>

        </div>



        <div class="card shadow-lg border-0 rounded-4">


            <div class="card-header bg-primary text-white">

                <h3 class="mb-0">
                    Account Information
                </h3>

            </div>



            <div class="card-body p-4">


                <div class="row g-4">


                    <div class="col-md-6">

                        <div class="border rounded p-3">

                            <label class="text-muted">
                                Username
                            </label>

                            <h5 class="fw-bold">

                                <i class="bi bi-person-circle"></i>

                                @Model.Username

                            </h5>

                        </div>

                    </div>



                    <div class="col-md-6">

                        <div class="border rounded p-3">

                            <label class="text-muted">
                                Role
                            </label>

                            <h5>

                                <span class="badge bg-primary">

                                    @Model.Role

                                </span>

                            </h5>

                        </div>

                    </div>



                    <div class="col-md-6">

                        <div class="border rounded p-3">

                            <label class="text-muted">
                                Employee Name
                            </label>

                            <h5 class="fw-bold">

                                @(Model.EmployeeName ?? "Not Assigned")

                            </h5>

                        </div>

                    </div>



                    <div class="col-md-6">

                        <div class="border rounded p-3">

                            <label class="text-muted">
                                Employee Code
                            </label>

                            <h5 class="fw-bold">

                                @(Model.EmployeeCode ?? "N/A")

                            </h5>

                        </div>

                    </div>



                    <div class="col-md-6">

                        <div class="border rounded p-3">

                            <label class="text-muted">
                                Department
                            </label>

                            <h5>

                                @(Model.Department ?? "N/A")

                            </h5>

                        </div>

                    </div>



                    <div class="col-md-6">

                        <div class="border rounded p-3">

                            <label class="text-muted">
                                Designation
                            </label>

                            <h5>

                                @(Model.Designation ?? "N/A")

                            </h5>

                        </div>

                    </div>



                    <div class="col-md-6">

                        <div class="border rounded p-3">

                            <label class="text-muted">
                                Account Status
                            </label>


                            <h5>

                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Inactive
                                    </span>
                                }

                            </h5>

                        </div>

                    </div>



                    <div class="col-md-6">

                        <div class="border rounded p-3">

                            <label class="text-muted">
                                Last Login
                            </label>


                            <h5>

                                @(Model.LastLogin?
                                .ToString("dd MMM yyyy hh:mm tt")
                                ?? "Never")

                            </h5>

                        </div>

                    </div>


                </div>



                <hr class="my-4" />



                <div class="text-end">


                    @if (await PermissionService.HasPermissionAsync("Profile.Edit"))
                    {
                        <a asp-controller="Profile"
                           asp-action="Edit"
                           class="btn btn-warning">

                            ✏ Edit Profile

                        </a>
                    }



                    @if (await PermissionService.HasPermissionAsync("Profile.ChangePassword"))
                    {
                        <a asp-controller="Profile"
                           asp-action="ChangePassword"
                           class="btn btn-danger ms-2">

                            🔑 Change Password

                        </a>
                    }


                </div>


            </div>


        </div>


    </div>

}
else
{

    <div class="alert alert-danger mt-4">

        You don't have permission to view profile.

    </div>

}