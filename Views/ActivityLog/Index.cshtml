@model EmployeeManagementSystem.ViewModels.ActivityReportViewModel
<nav aria-label="breadcrumb" class="mb-3 no-print">

    <ol class="breadcrumb">

        <li class="breadcrumb-item">

            <a asp-controller="Home"
               asp-action="Index">

                🏠 Home

            </a>

        </li>

        <li class="breadcrumb-item">

            <a asp-controller="Reports"
               asp-action="Index">

                📊 Reports

            </a>

        </li>

        <li class="breadcrumb-item active"
            aria-current="page">

            Activity Report

        </li>

    </ol>

</nav>
@{
    ViewData["Title"] = "Activity Logs";
}

<div class="container-fluid mt-4 mb-5 pb-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold text-primary">
                📜 Activity Logs
            </h2>

            <p class="text-muted mb-0">
                View all administrator activities performed in the system.
            </p>
        </div>

        <div>

          <div class="no-print">

    <a asp-controller="Reports"
       asp-action="Index"
       class="btn btn-secondary me-2">

        ←Back to Reports

    </a>


                @if (await PermissionService.HasPermissionAsync("ActivityLog.Print"))
                {
                    <button type="button"
                            class="btn btn-success"
                            onclick="window.print();">

                        🖨 Print Report

                    </button>
                }

</div>
        </div>

    </div>
   <form id="activityFilterForm"
      asp-action="Index"
      method="get"
      class="no-print">

        <div class="card shadow border-0 mb-4">

            <div class="card-header bg-secondary text-white">

                <h5 class="mb-0">
                    🔍 Search Filters
                </h5>

            </div>

            <div class="card-body">

                <div class="row g-3">

                    <div class="col-md-3">

                        <label class="form-label fw-bold">
                            Username
                        </label>

                        <input asp-for="Filter.Username"
                               name="username"
                               class="form-control"
                               placeholder="Enter username..." />

                    </div>

                    <div class="col-md-3">

                        <label class="form-label fw-bold">
                            Activity
                        </label>

                        <select asp-for="Filter.Activity"
                                name="activity"
                                asp-items="Model.ActivityTypes"
                                class="form-select">
                        </select>

                    </div>

                    <div class="col-md-2">

                        <label class="form-label fw-bold">
                            From
                        </label>

                        <input asp-for="Filter.FromDate"
                               name="fromDate"
                               type="date"
                               class="form-control" />

                    </div>

                    <div class="col-md-2">

                        <label class="form-label fw-bold">
                            To
                        </label>

                        <input asp-for="Filter.ToDate"
                               name="toDate"
                               type="date"
                               class="form-control" />

                    </div>

                    <div class="col-md-2 d-flex align-items-end">

                        <button class="btn btn-primary me-2">

                            🔍 Search

                        </button>

                        <a asp-action="Index"
                           class="btn btn-secondary">

                            Clear

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </form>

  <div id="reportContent"
     class="print-content">

    <partial name="_ActivityReportContent" model="Model" />

</div>

</div>

@section Scripts
{
    @if (ViewBag.Print == true)
    {
        <script>

            window.addEventListener("load", function () {

                setTimeout(function () {

                    window.print();

                }, 800);

            });

        </script>
    }
    <script>

        setupAjaxFilter("activityFilterForm", "reportContent");

    </script>
}