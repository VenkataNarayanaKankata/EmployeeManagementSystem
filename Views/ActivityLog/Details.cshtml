@model EmployeeManagementSystem.Models.ActivityLog
@{
    ViewData["Title"] = "Activity Details";
}
@if (await PermissionService.HasPermissionAsync("ActivityLog.Details"))
{
<div class="container mt-4">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-primary text-white">

            <h3 class="mb-0">
                📋 Activity Log Details
            </h3>

        </div>


        <div class="card-body p-4">

            <div class="row mb-4">

                <div class="col-md-4">
                    <label class="text-muted">
                        Username
                    </label>

                    <h5 class="fw-bold">
                        @Model.Username
                    </h5>
                </div>


                <div class="col-md-4">

                    <label class="text-muted">
                        Activity Date
                    </label>

                    <h5>
                        @Model.ActivityDate
                        .ToString("dd MMM yyyy hh:mm tt")
                    </h5>

                </div>


                <div class="col-md-4">

                    <label class="text-muted">
                        Log Id
                    </label>

                    <h5>
                        @Model.ActivityLogId
                    </h5>

                </div>

            </div>


            <hr />


            <div class="mb-4">

                <label class="text-muted">
                    Action Performed
                </label>


                <div class="alert alert-info">

                    @Model.Action

                </div>

            </div>


            <a asp-action="Index"
               class="btn btn-secondary">

                ← Back

            </a>


        </div>

    </div>

</div>
}
else
{
    <div class="alert alert-danger">
        You don't have permission to view activity details.
    </div>
}