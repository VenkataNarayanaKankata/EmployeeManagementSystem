@model EmployeeManagementSystem.ViewModels.ActivityReportViewModel
<div class="card shadow border-0">

    <div class="card-header bg-dark text-white">

        <h5 class="mb-0">
            System Activity History
        </h5>

    </div>

    <div class="card-body p-0">

        <div class="table-responsive">

            <table class="table table-striped table-hover table-bordered align-middle mb-0">

                <thead class="table-primary">

                    <tr>

                        <th width="70" class="text-center">
                            #
                        </th>

                        <th width="180">
                            User
                        </th>

                        <th>
                            Activity
                        </th>

                        <th width="220">
                            Date & Time
                        </th>

                        <th width="130" class="no-print">
                            Action
                        </th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model.Activities.Any())
                    {
                        int count = 1;

                        @foreach (var item in Model.Activities)
                        {
                            <tr>

                                <td class="text-center">
                                    @count
                                </td>

                                <td>
                                    <span class="badge bg-primary fs-6">
                                        @item.Username
                                    </span>
                                </td>

                                <td>
                                    @item.Action
                                </td>

                                <td>
                                    @item.ActivityDate.ToString("dd-MMM-yyyy hh:mm tt")
                                </td>
                                <td class="no-print">

                                    @if (await PermissionService.HasPermissionAsync("ActivityLog.Details"))
                                    {
                                        <a asp-controller="ActivityLog"
                                           asp-action="Details"
                                           asp-route-id="@item.ActivityLogId"
                                           class="btn btn-info btn-sm text-white">

                                            <i class="bi bi-eye-fill"></i>
                                            Details

                                        </a>
                                    }

                                </td>

                            </tr>

                            count++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">
                                <partial name="_NoRecordsFound" />
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <div class="card-footer bg-light">

        <div class="d-flex justify-content-between">

            <strong>

                Total Activities :
                @Model.Activities.Count

            </strong>

            <span class="text-muted">

                Employee Management System

            </span>

        </div>

    </div>

</div>
