@model EmployeeManagementSystem.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-page">


    <section class="dashboard-hero">

        <div class="dashboard-hero-content">

            <span class="dashboard-badge">
                <i class="bi bi-grid-1x2-fill"></i>
                Dashboard Overview
            </span>


            <h1>
                Welcome Back,
                <span>
                    @(User.IsInRole("Admin") ? "Administrator" :
                    User.IsInRole("HR") ? "HR" :
                    User.IsInRole("Manager") ? "Manager" :
                    User.IsInRole("Employee") ? "Employee" :
                    "User")
                </span>
                👋
            </h1>


            <p>
                Monitor employees, branches, departments and organization insights from one place.
            </p>

        </div>


        <div class="dashboard-date-card">

            <div class="date-icon">
                <i class="bi bi-calendar-event"></i>
            </div>


            <div>

                <small>
                    Today
                </small>

                <h4>
                    @DateTime.Now.ToString("dddd")
                </h4>

                <p>
                    @DateTime.Now.ToString("dd MMMM yyyy")
                </p>

            </div>

        </div>

    </section>





    <section class="dashboard-kpi-section">

        <div class="kpi-grid">


            <div class="kpi-card">
                <div class="kpi-icon blue">
                    <i class="bi bi-people-fill"></i>
                </div>

                <div>
                    <span>Total Employees</span>
                    <h2>@Model.TotalEmployees</h2>
                    <small>Total workforce</small>
                </div>
            </div>



            <div class="kpi-card">
                <div class="kpi-icon green">
                    <i class="bi bi-building"></i>
                </div>

                <div>
                    <span>Branches</span>
                    <h2>@Model.TotalBranches</h2>
                    <small>Company locations</small>
                </div>
            </div>




            <div class="kpi-card">
                <div class="kpi-icon orange">
                    <i class="bi bi-diagram-3"></i>
                </div>

                <div>
                    <span>Departments</span>
                    <h2>@Model.TotalDepartments</h2>
                    <small>Organization units</small>
                </div>
            </div>




            <div class="kpi-card">
                <div class="kpi-icon purple">
                    <i class="bi bi-person-badge"></i>
                </div>

                <div>
                    <span>Designations</span>
                    <h2>@Model.TotalDesignations</h2>
                    <small>Job positions</small>
                </div>
            </div>



            <div class="kpi-card">
                <div class="kpi-icon blue">
                    <i class="bi bi-person-check"></i>
                </div>

                <div>
                    <span>Active Employees</span>
                    <h2>@Model.ActiveEmployees</h2>
                    <small>Currently working</small>
                </div>
            </div>



            <div class="kpi-card">
                <div class="kpi-icon green">
                    <i class="bi bi-calendar-plus"></i>
                </div>

                <div>
                    <span>New Joiners</span>
                    <h2>@Model.JoinedThisMonth</h2>
                    <small>This month</small>
                </div>
            </div>



            <div class="kpi-card">
                <div class="kpi-icon orange">
                    <i class="bi bi-cash-stack"></i>
                </div>

                <div>
                    <span>Average Salary</span>
                    <h2>₹ @Model.AverageSalary.ToString("N0")</h2>
                    <small>Monthly average</small>
                </div>
            </div>



            <div class="kpi-card">
                <div class="kpi-icon purple">
                    <i class="bi bi-wallet2"></i>
                </div>

                <div>
                    <span>Highest Salary</span>
                    <h2>₹ @Model.HighestSalary.ToString("N0")</h2>
                    <small>Highest package</small>
                </div>
            </div>



        </div>

    </section>





    <section class="dashboard-analytics-section">

        <div class="analytics-grid">


            <div class="analytics-card">

                <h3>
                    Employees By Branch
                </h3>

                <div class="chart-container">
                    <canvas id="branchChart"></canvas>
                </div>

            </div>




            <div class="analytics-card">

                <h3>
                    Top Departments
                </h3>

                <div class="chart-container">
                    <canvas id="departmentChart"></canvas>
                </div>

            </div>





            <div class="analytics-card">

                <h3>
                    Top Designations
                </h3>

                <div class="chart-container">
                    <canvas id="designationChart"></canvas>
                </div>

            </div>





            <div class="analytics-card">

                <h3>
                    Employee Roles
                </h3>

                <div class="chart-container">

                    <canvas id="roleChart"></canvas>

                </div>

            </div>


        </div>

    </section>





    <section class="dashboard-actions-section">

        <div class="section-title">

            <h2>
                Quick Actions
            </h2>

            <p>
                Manage organization modules quickly.
            </p>

        </div>



        <div class="actions-grid">


            @if (User.IsInRole("Admin") || User.IsInRole("HR"))
            {

                <a asp-controller="Employee"
                   asp-action="Create"
                   class="action-card">

                    <i class="bi bi-person-plus"></i>

                    <span>
                        Add Employee
                    </span>

                </a>



                <a asp-controller="Import"
                   asp-action="EmployeeImport"
                   class="action-card">

                    <i class="bi bi-upload"></i>

                    <span>
                        Import Employees
                    </span>

                </a>

            }



            @if (User.IsInRole("Admin"))
            {


                <a asp-controller="Branch"
                   asp-action="Index"
                   class="action-card">

                    <i class="bi bi-building"></i>

                    <span>
                        Branches
                    </span>

                </a>



                <a asp-controller="Department"
                   asp-action="Index"
                   class="action-card">

                    <i class="bi bi-diagram-3"></i>

                    <span>
                        Departments
                    </span>

                </a>



                <a asp-controller="Designation"
                   asp-action="Index"
                   class="action-card">

                    <i class="bi bi-person-badge"></i>

                    <span>
                        Designations
                    </span>

                </a>


            }
            @if (User.IsInRole("Admin"))
            {

                <a asp-controller="User"
                   asp-action="Index"
                   class="action-card">

                    <i class="bi bi-people-fill"></i>

                    <span>
                        User Management
                    </span>

                </a>


                <a asp-controller="ActivityLog"
                   asp-action="Index"
                   class="action-card">

                    <i class="bi bi-clock-history"></i>

                    <span>
                        Activity Logs
                    </span>

                </a>

            }



            @if (User.IsInRole("Admin") || User.IsInRole("HR"))
            {

                <a asp-controller="Reports"
                   asp-action="Index"
                   class="action-card">

                    <i class="bi bi-file-earmark-bar-graph"></i>

                    <span>
                        Reports
                    </span>

                </a>

            }


        </div>


    </section>






    <section class="recent-section">


        <div class="recent-card">


            <div class="d-flex justify-content-between mb-4">

                <h2>
                    Latest Employees
                </h2>


                <a asp-controller="Employee"
                   asp-action="Index"
                   class="btn btn-primary">

                    View All

                </a>

            </div>





            <div class="table-responsive">


                <table class="table table-hover">


                    <thead>

                        <tr>

                            <th>
                                Photo
                            </th>

                            <th>
                                Employee
                            </th>

                            <th>
                                Branch
                            </th>

                            <th>
                                Department
                            </th>

                            <th>
                                Designation
                            </th>

                            <th>
                                Role
                            </th>

                            <th>
                                Joining Date
                            </th>

                        </tr>

                    </thead>



                    <tbody>


                        @foreach (var employee in Model.RecentEmployees)
                        {

                            <tr>


                                <td>

                                    @if (!string.IsNullOrEmpty(employee.PhotoPath))
                                    {

                                        <img src="~/uploads/@employee.PhotoPath"
                                             width="55"
                                             height="55"
                                             class="rounded-circle" />

                                    }
                                    else
                                    {

                                        <img src="~/images/default-user.png"
                                             width="55"
                                             height="55"
                                             class="rounded-circle" />

                                    }

                                </td>



                                <td>

                                    <strong>
                                        @employee.FirstName @employee.LastName
                                    </strong>

                                    <br />

                                    <small>
                                        @employee.Email
                                    </small>

                                </td>



                                <td>
                                    @employee.Branch?.BranchName
                                </td>



                                <td>
                                    @employee.Department?.DepartmentName
                                </td>



                                <td>
                                    @employee.Designation?.DesignationName
                                </td>



                                <td>
                                    @employee.Role?.RoleName
                                </td>



                                <td>
                                    @employee.JoiningDate.ToString("dd MMM yyyy")
                                </td>


                            </tr>

                        }


                    </tbody>


                </table>


            </div>


        </div>


    </section>


</div>





@section Scripts
{

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>


    <script>


        function createChart(id, labels, data, type) {

            new Chart(document.getElementById(id),
                {

                    type: type,

                    data:
                    {

                        labels: labels,

                        datasets:
                            [{

                                data: data

                            }]

                    },

                    options:
                    {

                        responsive: true,

                        maintainAspectRatio: false

                    }

                });


        }



        createChart(
            "branchChart",
        @Html.Raw(Json.Serialize(Model.BranchNames)),
        @Html.Raw(Json.Serialize(Model.BranchEmployeeCounts)),
            "bar"
        );



        createChart(
            "departmentChart",
        @Html.Raw(Json.Serialize(Model.TopDepartmentNames)),
        @Html.Raw(Json.Serialize(Model.TopDepartmentCounts)),
            "bar"
        );



        createChart(
            "designationChart",
        @Html.Raw(Json.Serialize(Model.TopDesignationNames)),
        @Html.Raw(Json.Serialize(Model.TopDesignationCounts)),
            "bar"
        );
        const roleCtx = document.getElementById('roleChart');


        const roleChartElement = document.getElementById("roleChart");

        if (roleChartElement) {

            new Chart(roleChartElement, {

                type: "doughnut",

                data: {

                    labels: @Html.Raw(Json.Serialize(Model.RoleNames)),

                    datasets: [
                        {
                            data: @Html.Raw(Json.Serialize(Model.RoleEmployeeCounts))
                    }
                    ]

                },


                options: {

                    responsive: true,

                    maintainAspectRatio: false,

                    plugins: {

                        legend: {

                            position: "right"

                        }

                    }

                }

            });

        }


    </script>

}