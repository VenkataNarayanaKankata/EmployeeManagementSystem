@model IEnumerable<EmployeeManagementSystem.Models.Employee>

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">

    <h2 class="mb-4 text-center">
        Employee Management Dashboard
    </h2>

    <div class="row g-4">

        <!-- Total Employees -->
        <div class="col-md-4">
            <div class="card bg-primary text-white shadow border-0 rounded-4">
                <div class="card-body">
                    <h6>👨‍💼 Total Employees</h6>
                    <h2>@ViewBag.TotalEmployees</h2>
                </div>
            </div>
        </div>

        <!-- Total Departments -->
        <div class="col-md-4">
            <div class="card bg-success text-white shadow border-0 rounded-4">
                <div class="card-body">
                    <h6>🏢 Total Departments</h6>
                    <h2>@ViewBag.TotalDepartments</h2>
                </div>
            </div>
        </div>

        <!-- Average Salary -->
        <div class="col-md-4">
            <div class="card bg-warning text-white shadow border-0 rounded-4">
                <div class="card-body">
                    <h6>💰 Average Salary</h6>
                    <h2>₹ @ViewBag.AverageSalary</h2>
                </div>
            </div>
        </div>

        <!-- Highest Salary -->
        <div class="col-md-4">
            <div class="card bg-info text-white shadow border-0 rounded-4">
                <div class="card-body">
                    <h6>📈 Highest Salary</h6>
                    <h2>₹ @ViewBag.HighestSalary</h2>
                </div>
            </div>
        </div>

        <!-- Lowest Salary -->
        <div class="col-md-4">
            <div class="card bg-danger text-white shadow border-0 rounded-4">
                <div class="card-body">
                    <h6>📉 Lowest Salary</h6>
                    <h2>₹ @ViewBag.LowestSalary</h2>
                </div>
            </div>
        </div>

        <!-- Joined This Month -->
        <div class="col-md-4">
            <div class="card bg-secondary text-white shadow border-0 rounded-4">
                <div class="card-body">
                    <h6>📅 Joined This Month</h6>
                    <h2>@ViewBag.JoinedThisMonth</h2>
                </div>
            </div>
        </div>

    </div>
    <hr />
    <div class="row mb-5">

        <!-- Bar Chart -->
        <div class="col-lg-6 mb-4">

            <div class="card shadow h-100">

                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">📊 Employees per Department</h5>
                </div>

                <div class="card-body d-flex justify-content-center align-items-center">

                    <canvas id="departmentChart"
                            style="height:320px; max-height:320px;"></canvas>

                </div>

            </div>

        </div>

        <!-- Pie Chart -->
        <div class="col-lg-6 mb-4">

            <div class="card shadow h-100">

                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">🥧 Department Distribution</h5>
                </div>

                <div class="card-body d-flex justify-content-center align-items-center">

                    <canvas id="pieChart"
                            style="height:320px; max-height:320px;"></canvas>

                </div>

            </div>

        </div>


    </div>
   

</div>

    <!-- Quick Actions -->
    <div class="card shadow border-0 rounded-4 my-4">

        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">⚡ Quick Actions</h5>
        </div>

        <div class="card-body">

            <div class="row text-center">

                <div class="col-md-3 mb-3">
                    <a asp-controller="Employee"
                       asp-action="Create"
                       class="btn btn-primary w-100 py-3">
                        ➕<br />
                        Add Employee
                    </a>
                </div>

                <div class="col-md-3 mb-3">
                    <a asp-controller="Department"
                       asp-action="Create"
                       class="btn btn-success w-100 py-3">
                        🏢<br />
                        Add Department
                    </a>
                </div>

                <div class="col-md-3 mb-3">
                    <a asp-controller="Employee"
                       asp-action="ExportToExcel"
                       class="btn btn-warning text-dark w-100 py-3">
                        📊<br />
                        Export Excel
                    </a>
                </div>

                <div class="col-md-3 mb-3">
                    <a asp-controller="Employee"
                       asp-action="ExportToPdf"
                       class="btn btn-danger w-100 py-3">
                        📄<br />
                        Export PDF
                    </a>
                </div>

            </div>

        </div>

    </div>

@section Scripts
{
    <script>

        const departmentNames =
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.DepartmentNames));

        const employeeCounts =
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.EmployeeCounts));

        // BAR CHART
              new Chart(document.getElementById('departmentChart'), {

            type: 'bar',

            data: {
                labels: departmentNames,
                datasets: [{
                    label: 'Employees',
                    data: employeeCounts,
                    backgroundColor: [
                        '#0d6efd',
                        '#198754',
                        '#ffc107',
                        '#dc3545',
                        '#6f42c1',
                        '#20c997'
                    ],
                    borderRadius: 10,
                    borderSkipped: false
                }]
            },

            options: {

                responsive: true,

                maintainAspectRatio: false,

                plugins: {
                    legend: {
                        display: false
                    }
                },

                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1
                        }
                    }
                }
            }
        });
        // PIE CHART
               new Chart(document.getElementById('pieChart'), {

            type: 'pie',

            data: {

                labels: departmentNames,

                datasets: [{

                    data: employeeCounts,

                    backgroundColor: [
                        '#0d6efd',
                        '#198754',
                        '#ffc107',
                        '#dc3545',
                        '#6f42c1',
                        '#20c997'
                    ]

                }]
            },

            options: {

                responsive: true,

                maintainAspectRatio: false,

                plugins: {

                    legend: {

                        position: 'bottom'

                    }

                }

            }

        });

    </script>
}