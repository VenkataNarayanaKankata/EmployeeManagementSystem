@model EmployeeManagementSystem.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}


<!-- =====================================================
                    DASHBOARD PAGE
====================================================== -->


<div class="dashboard-page">


    <!-- =================================================
                    DASHBOARD HERO
    ================================================== -->


    <section class="dashboard-hero">


        <div class="dashboard-hero-content">


            <span class="dashboard-badge">

                <i class="bi bi-grid-1x2-fill"></i>

                Dashboard Overview

            </span>



            <h1>

                Welcome Back,
                <span>
                    Admin
                </span>
                👋

            </h1>



            <p>

                Monitor your workforce,
                employee performance,
                departments and business insights
                from one centralized dashboard.

            </p>


        </div>




        <!-- DATE CARD -->


        <div class="dashboard-date-card">


            <div class="date-icon">

                <i class="bi bi-calendar-event"></i>

            </div>



            <div>


                <small>

                    Today

                </small>


                <h4>

                    @DateTime.Now.ToString("dddd")

                </h4>


                <p>

                    @DateTime.Now.ToString("dd MMMM yyyy")

                </p>


            </div>



        </div>


    </section>





    <!-- =================================================
                    KPI CARDS
    ================================================== -->


    <section class="dashboard-kpi-section">


        <div class="kpi-grid">



            <!-- TOTAL EMPLOYEES -->


            <div class="kpi-card">


                <div class="kpi-icon blue">

                    <i class="bi bi-people-fill"></i>

                </div>



                <div class="kpi-content">


                    <span>

                        Total Employees

                    </span>


                    <h2>

                        @Model.TotalEmployees

                    </h2>


                    <small>

                        Active workforce

                    </small>


                </div>


            </div>






            <!-- DEPARTMENTS -->


            <div class="kpi-card">


                <div class="kpi-icon green">

                    <i class="bi bi-building-fill"></i>

                </div>



                <div class="kpi-content">


                    <span>

                        Departments

                    </span>


                    <h2>

                        @Model.TotalDepartments

                    </h2>


                    <small>

                        Company structure

                    </small>


                </div>


            </div>






            <!-- SALARY -->


            <div class="kpi-card">


                <div class="kpi-icon orange">

                    <i class="bi bi-currency-rupee"></i>

                </div>



                <div class="kpi-content">


                    <span>

                        Average Salary

                    </span>

                    <h2>

                        ₹ @Convert.ToDecimal(Model.AverageSalary).ToString("N0")

                    </h2>


                    <small>

                        Monthly average

                    </small>


                </div>


            </div>






            <!-- JOINED -->


            <div class="kpi-card">


                <div class="kpi-icon purple">

                    <i class="bi bi-person-plus-fill"></i>

                </div>



                <div class="kpi-content">


                    <span>

                        New Joiners

                    </span>


                    <h2>

                        @Model.JoinedThisMonth

                    </h2>


                    <small>

                        This month

                    </small>


                </div>


            </div>



        </div>


    </section>
    <!-- =====================================================
                ANALYTICS SECTION
====================================================== -->


    <section class="dashboard-analytics-section">


        <div class="analytics-grid">



            <!-- =============================================
                EMPLOYEE ANALYTICS
        ============================================== -->


            <div class="analytics-card">


                <div class="analytics-header">


                    <div>


                        <h3>

                            Employee Analytics

                        </h3>


                        <p>

                            Workforce distribution overview

                        </p>


                    </div>



                    <div class="analytics-icon">

                        <i class="bi bi-bar-chart-fill"></i>

                    </div>


                </div>



                <div class="chart-container">


                    <canvas id="employeeChart"></canvas>


                </div>


            </div>







            <!-- =============================================
                DEPARTMENT ANALYTICS
        ============================================== -->


            <div class="analytics-card">


                <div class="analytics-header">


                    <div>


                        <h3>

                            Department Distribution

                        </h3>


                        <p>

                            Employees by department

                        </p>


                    </div>



                    <div class="analytics-icon">


                        <i class="bi bi-pie-chart-fill"></i>


                    </div>


                </div>



                <div class="chart-container">


                    <canvas id="departmentChart"></canvas>


                </div>



            </div>




        </div>


    </section>
    <!-- =====================================================
                QUICK ACTIONS SECTION
====================================================== -->


    <section class="dashboard-actions-section">


        <div class="section-title">


            <div>

                <span class="dashboard-badge">

                    <i class="bi bi-lightning-fill"></i>

                    Quick Actions

                </span>


                <h2>

                    Manage Your Workspace

                </h2>


                <p>

                    Quickly access frequently used employee
                    management features.

                </p>


            </div>


        </div>





        <div class="actions-grid">



            <!-- ADD EMPLOYEE -->


            <a asp-controller="Employee"
               asp-action="Create"
               class="action-card">


                <div class="action-icon blue">

                    <i class="bi bi-person-plus-fill"></i>

                </div>



                <div class="action-content">


                    <h4>

                        Add Employee

                    </h4>


                    <p>

                        Create a new employee record.

                    </p>


                </div>



                <i class="bi bi-arrow-right action-arrow"></i>


            </a>







            <!-- DEPARTMENT -->


            <a asp-controller="Department"
               asp-action="Create"
               class="action-card">


                <div class="action-icon green">


                    <i class="bi bi-building-add"></i>


                </div>



                <div class="action-content">


                    <h4>

                        Add Department

                    </h4>


                    <p>

                        Organize company departments.

                    </p>


                </div>



                <i class="bi bi-arrow-right action-arrow"></i>


            </a>







            <!-- IMPORT -->


            <a asp-controller="Import"
               asp-action="EmployeeImport"
               class="action-card">


                <div class="action-icon orange">


                    <i class="bi bi-file-earmark-arrow-up-fill"></i>


                </div>



                <div class="action-content">


                    <h4>

                        Import Employees

                    </h4>


                    <p>

                        Upload bulk employee data.

                    </p>


                </div>



                <i class="bi bi-arrow-right action-arrow"></i>


            </a>







            <!-- REPORTS -->


            <a asp-controller="Reports"
               asp-action="Index"
               class="action-card">


                <div class="action-icon purple">


                    <i class="bi bi-file-earmark-bar-graph-fill"></i>


                </div>



                <div class="action-content">


                    <h4>

                        View Reports

                    </h4>


                    <p>

                        Generate employee reports.

                    </p>


                </div>



                <i class="bi bi-arrow-right action-arrow"></i>


            </a>




        </div>


    </section>
    <!-- =====================================================
                RECENT EMPLOYEES SECTION
====================================================== -->


    <section class="recent-section">


        <div class="recent-card">


            <div class="recent-header">


                <div>

                    <span class="dashboard-badge">

                        <i class="bi bi-people-fill"></i>

                        Recent Employees

                    </span>


                    <h2>

                        Latest Employee Records

                    </h2>


                </div>



                <a asp-controller="Employee"
                   asp-action="Index"
                   class="btn btn-primary">


                    View All

                    <i class="bi bi-arrow-right ms-2"></i>


                </a>


            </div>





            <div class="table-responsive">


                <table class="table employee-table">


                    <thead>

                        <tr>

                            <th>
                                Employee
                            </th>

                            <th>
                                Department
                            </th>

                            <th>
                                Joining Date
                            </th>

                            <th>
                                Status
                            </th>

                            <th>
                                Action
                            </th>

                        </tr>


                    </thead>



                    <tbody>


                        @if (Model.RecentEmployees != null &&
                            Model.RecentEmployees.Any())
                        {

                            foreach (var employee in Model.RecentEmployees)
                            {

                                <tr>


                                    <td>


                                        <div class="employee-profile">


                                            @if (!string.IsNullOrEmpty(employee.PhotoPath))
                                            {

                                                <img src="~/uploads/@employee.PhotoPath"
                                                     asp-append-version="true"
                                                     class="employee-avatar" />

                                            }
                                            else
                                            {

                                                <img src="~/images/default-user.png"
                                                     class="employee-avatar" />

                                            }



                                            <div>


                                                <h6>

                                                    @employee.FirstName
                                                    @employee.LastName

                                                </h6>


                                                <span>

                                                    @employee.Email

                                                </span>


                                            </div>


                                        </div>


                                    </td>



                                    <td>

                                        @employee.Department?.DepartmentName

                                    </td>



                                    

                                        <td>
                                            @employee.JoiningDate.ToString("dd MMM yyyy")
                                        </td>



                                    <td>


                                        <span class="status-active">

                                            Active

                                        </span>


                                    </td>



                                    <td>


                                        <a asp-controller="Employee"
                                           asp-action="Details"
                                           asp-route-id="@employee.EmployeeId"
                                           class="btn btn-sm btn-outline-primary">


                                            View


                                        </a>


                                    </td>



                                </tr>


                            }

                        }
                        else
                        {

                            <tr>

                                <td colspan="5"
                                    class="text-center">

                                    No employee records found.

                                </td>

                            </tr>

                        }


                    </tbody>


                </table>


            </div>


        </div>


    </section>





    <!-- =====================================================
                CHART SCRIPTS
====================================================== -->
    @section Scripts
    {

        <script>


                const departmentNames =
                @Html.Raw(
                        System.Text.Json.JsonSerializer.Serialize(
                                Model.DepartmentNames
                        )
                );


                const employeeCounts =
                @Html.Raw(
                        System.Text.Json.JsonSerializer.Serialize(
                                Model.EmployeeCounts
                        )
                );



                // EMPLOYEE BAR CHART

                new Chart(
                    document.getElementById("employeeChart"),
                    {

                        type:"bar",

                        data:
                        {

                            labels:departmentNames,

                            datasets:
                            [
                                {

                                    label:"Employees",

                                    data:employeeCounts,

                                    borderRadius:12,

                                    backgroundColor:
                                    [
                                        "#2563EB",
                                        "#16A34A",
                                        "#F59E0B",
                                        "#DC2626",
                                        "#9333EA"
                                    ]

                                }

                            ]

                        },


                        options:
                        {

                            responsive:true,

                            maintainAspectRatio:false,


                            plugins:
                            {

                                legend:
                                {

                                    display:false

                                }

                            },


                            scales:
                            {

                                y:
                                {

                                    beginAtZero:true

                                }

                            }


                        }


                    }
                );





                // DEPARTMENT PIE CHART


                new Chart(
                    document.getElementById("departmentChart"),
                    {

                        type:"doughnut",


                        data:
                        {

                            labels:departmentNames,


                            datasets:
                            [
                                {

                                    data:employeeCounts,


                                    backgroundColor:
                                    [
                                        "#2563EB",
                                        "#16A34A",
                                        "#F59E0B",
                                        "#DC2626",
                                        "#9333EA"
                                    ]


                                }

                            ]


                        },


                        options:
                        {

                            responsive:true,

                            maintainAspectRatio:false,


                            plugins:
                            {

                                legend:
                                {

                                    position:"bottom"

                                }

                            }


                        }


                    }
                );


        </script>

    }