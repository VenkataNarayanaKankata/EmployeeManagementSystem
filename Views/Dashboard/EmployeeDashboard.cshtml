@model EmployeeManagementSystem.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Employee Dashboard";
}

<div class="container-fluid py-4">

    <!-- ===============================
            HERO SECTION
    ================================ -->

    <div class="employee-dashboard-banner">

        <div class="banner-content">

            <span class="dashboard-badge">

                <i class="bi bi-person-workspace"></i>

                Employee Dashboard

            </span>

            <h1 class="mt-3">

                Welcome Back,

                @User.Identity?.Name 👋

            </h1>

            <p>

                View your profile information and manage your account from one place.

            </p>

        </div>

        <div class="banner-date">

            <div class="date-card">

                <i class="bi bi-calendar-event"></i>

                <h4>

                    @DateTime.Now.ToString("dddd")

                </h4>

                <span>

                    @DateTime.Now.ToString("dd MMM yyyy")

                </span>

            </div>

        </div>

    </div>


    <!-- ===============================
        QUICK ACTIONS
================================ -->

    <div class="row mt-4 g-4">

        <!-- My Profile -->

        <div class="col-lg-6">

            <div class="employee-card">

                <div class="card-icon bg-primary">

                    <i class="bi bi-person-circle"></i>

                </div>

                <div>

                    <h4>

                        My Profile

                    </h4>

                    <p>

                        View and manage your personal profile information.

                    </p>

                    <a asp-controller="Profile"
                       asp-action="Index"
                       class="btn btn-primary rounded-pill">

                        View Profile

                    </a>

                </div>

            </div>

        </div>

        <!-- My Account -->

        <div class="col-lg-6">

            <div class="employee-card">

                <div class="card-icon bg-info">

                    <i class="bi bi-person-badge-fill"></i>

                </div>

                <div>

                    <h4>

                        My Account

                    </h4>

                    <p>

                        View your account details and current role information.

                    </p>

                    <div class="mt-3">

                        <span class="badge bg-primary me-2">

                            Employee

                        </span>

                        <span class="badge bg-success">

                            Active

                        </span>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- ===============================
            INFORMATION
    ================================ -->

    <div class="employee-info-card mt-5">

        <div class="info-header">

            <h3>

                <i class="bi bi-person-vcard-fill"></i>

                My Information

            </h3>

        </div>

        <table class="table table-borderless align-middle mb-0">

            <tbody>

                <tr>

                    <th>

                        Username

                    </th>

                    <td>

                        @User.Identity?.Name

                    </td>

                </tr>

                <tr>

                    <th>

                        Role

                    </th>

                    <td>

                        <span class="badge bg-primary">

                            Employee

                        </span>

                    </td>

                </tr>

                <tr>

                    <th>

                        Account Status

                    </th>

                    <td>

                        <span class="badge bg-success">

                            Active

                        </span>

                    </td>

                </tr>

                <tr>

                    <th>

                        Login Date

                    </th>

                    <td>

                        @DateTime.Now.ToString("dd MMM yyyy")

                    </td>

                </tr>

                <tr>

                    <th>

                        Login Time

                    </th>

                    <td>

                        @DateTime.Now.ToString("hh:mm tt")

                    </td>

                </tr>

            </tbody>
        </table>

    </div>

</div>