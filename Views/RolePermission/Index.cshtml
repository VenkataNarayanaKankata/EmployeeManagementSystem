@model EmployeeManagementSystem.ViewModels.RolePermissionViewModel

@{
    ViewData["Title"] = "Role Permission Management";
}


@if (await PermissionService.HasPermissionAsync("Role.AssignPermission"))
{

    <div class="container-fluid py-4">


        <div class="mb-4">

            <h1 class="fw-bold text-primary">
                🔐 Role Permission Management
            </h1>

            <p class="text-muted">
                Assign module based permissions to roles and control system access.
            </p>

        </div>



        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success shadow-sm">
                @TempData["Success"]
            </div>
        }


        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger shadow-sm">
                @TempData["Error"]
            </div>
        }



        <div class="card shadow border-0 mb-4">


            <div class="card-header bg-primary text-white">

                <h5 class="mb-0">
                    👤 Select Role
                </h5>

            </div>


            <div class="card-body">


                <form method="get"
                      asp-action="Index">


                    <select name="roleId"
                            class="form-select form-select-lg"
                            onchange="this.form.submit()">


                        <option value="">
                            -- Select Role --
                        </option>


                        @foreach (var role in ViewBag.Roles)
                        {

                            <option value="@role.RoleId"
                                    selected="@(Model.RoleId == role.RoleId)">

                                @role.RoleName

                            </option>

                        }


                    </select>


                </form>


            </div>


        </div>




        @if (Model.RoleId > 0)
        {


            <form asp-action="Index"
                  method="post">


                <input type="hidden"
                       asp-for="RoleId" />



                <div class="card shadow border-0 mb-4">


                    <div class="card-header bg-dark text-white">

                        <h5 class="mb-0">
                            📂 Permission Modules
                        </h5>

                    </div>



                    <div class="card-body">


                        <div class="row">


                            @foreach (var module in Model.Modules)
                            {

                                <div class="col-lg-3 col-md-4 mb-3">


                                    <div class="module-card">


                                        <div class="form-check">


                                            <input class="form-check-input module-checkbox"
                                                   type="checkbox"
                                                   value="@module"
                                                   data-module="@module"
                                                   checked />



                                            <label class="form-check-label fw-semibold">

                                                @module

                                            </label>


                                        </div>


                                    </div>


                                </div>


                            }


                        </div>


                    </div>


                </div>





                <div class="card shadow border-0">


                    <div class="card-header bg-success text-white">


                        <h5 class="mb-0">

                            Permissions For : @Model.RoleName

                        </h5>


                    </div>



                    <div class="card-body">


                        @{

                            var grouped =
                            Model.Permissions
                            .GroupBy(x => x.ModuleName);

                        }



                        @foreach (var group in grouped)
                        {


                            <div class="permission-section mb-4">


                                <div class="d-flex justify-content-between align-items-center mb-3">


                                    <h5 class="text-primary">

                                        📁 @group.Key

                                    </h5>


                                    <div>


                                        <input type="checkbox"
                                               class="select-all"
                                               data-module="@group.Key" />


                                        <label>
                                            Select All
                                        </label>


                                    </div>


                                </div>




                                <div class="row">


                                    @foreach (var permission in group)
                                    {


                                        var index =
                                        Model.Permissions.IndexOf(permission);



                                        <input type="hidden"
                                               asp-for="Permissions[index].PermissionId" />


                                        <input type="hidden"
                                               asp-for="Permissions[index].PermissionName" />


                                        <input type="hidden"
                                               asp-for="Permissions[index].ModuleName" />



                                        <div class="col-lg-4 col-md-6 mb-3">


                                            <div class="permission-card">


                                                <div class="form-check">


                                                    <input class="form-check-input permission-checkbox"
                                                           asp-for="Permissions[index].IsSelected"
                                                           data-module="@permission.ModuleName" />



                                                    <label class="form-check-label">

                                                        @permission.PermissionName

                                                    </label>


                                                </div>


                                            </div>


                                        </div>


                                    }


                                </div>


                            </div>


                        }



                    </div>



                    <div class="card-footer text-end">


                        <button type="submit"
                                class="btn btn-success btn-lg">


                            💾 Save Permissions


                        </button>


                    </div>


                </div>


            </form>


        }
        else
        {

            <div class="alert alert-info">

                Please select role to manage permissions.

            </div>

        }



    </div>


}
else
{

    <div class="alert alert-danger">

        You don't have permission to manage role permissions.

    </div>

}





@section Scripts
{

    <script>


        document
            .querySelectorAll(".select-all")
            .forEach(btn => {


                btn.addEventListener("change", function() {


                    let module = this.dataset.module;


                    document
                        .querySelectorAll(
                            '.permission-checkbox[data-module="' + module + '"]'
                        )
                        .forEach(x => {


                            x.checked = this.checked;


                        });


                });


            });





    </script>


}