@model EmployeeManagementSystem.Models.Designation

@{
    ViewData["Title"] = "Delete Designation";
}

<div class="container-fluid py-4">

    <div class="card shadow-sm border-0 rounded-4">


        <div class="card-header bg-danger text-white">

            <h3 class="mb-0">

                <i class="bi bi-trash-fill"></i>

                Delete Designation

            </h3>

        </div>


        <div class="card-body p-4">


            <div class="alert alert-warning">

                <i class="bi bi-exclamation-triangle-fill"></i>

                Are you sure you want to delete this designation?

                <br />

                Designations with employees cannot be deleted.

            </div>


            <div class="row mb-3">

                <div class="col-md-3">

                    <strong>

                        Designation Code

                    </strong>

                </div>


                <div class="col-md-9">

                    @Model.DesignationCode

                </div>

            </div>



            <div class="row mb-3">

                <div class="col-md-3">

                    <strong>

                        Designation Name

                    </strong>

                </div>


                <div class="col-md-9">

                    @Model.DesignationName

                </div>

            </div>



            <div class="row mb-3">

                <div class="col-md-3">

                    <strong>

                        Department

                    </strong>

                </div>


                <div class="col-md-9">

                    @Model.Department?.DepartmentName

                </div>

            </div>



            <hr />


            <form asp-action="Delete">


                <input type="hidden"
                       asp-for="DesignationId" />


                <a asp-action="Index"
                   class="btn btn-secondary">

                    <i class="bi bi-arrow-left"></i>

                    Cancel

                </a>



                <button type="submit"
                        class="btn btn-danger"
                        onclick="return confirm('Are you sure you want to delete this designation?');">


                    <i class="bi bi-trash"></i>

                    Delete Designation


                </button>


            </form>


        </div>


    </div>


</div>