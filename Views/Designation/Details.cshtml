@model EmployeeManagementSystem.Models.Designation

@{
    ViewData["Title"] = "Designation Details";

    var totalEmployees = Model.Employees?.Count(e => !e.IsDeleted) ?? 0;
    var activeEmployees = Model.Employees?.Count(e => !e.IsDeleted && e.IsActive) ?? 0;
    var inactiveEmployees = Model.Employees?.Count(e => !e.IsDeleted && !e.IsActive) ?? 0;
}

@if(await PermissionService.HasPermissionAsync("Designation.ViewDetails"))
{

<div class="container-fluid py-4">

    <div class="card shadow-sm border-0 rounded-4">

        <div class="card-header bg-info text-white">

            <h3 class="mb-0">

                <i class="bi bi-person-badge-fill"></i>

                Designation Details

            </h3>

        </div>


        <div class="card-body p-4">


            <div class="row mb-4">

                <div class="col-md-6">

                    <label class="fw-bold text-primary">

                        Designation Code

                    </label>

                    <h5 class="mt-2">

                        @Model.DesignationCode

                    </h5>

                </div>


                <div class="col-md-6">

                    <label class="fw-bold text-primary">

                        Designation Name

                    </label>

                    <h5 class="mt-2">

                        @Model.DesignationName

                    </h5>

                </div>

            </div>


            <div class="row mb-4">

                <div class="col-md-6">

                    <label class="fw-bold text-primary">

                        Department

                    </label>

                    <h5 class="mt-2">

                        @Model.Department?.DepartmentName

                    </h5>

                </div>


                <div class="col-md-6">

                    <label class="fw-bold text-primary">

                        Status

                    </label>

                    <div class="mt-2">

                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success fs-6">

                                Active

                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger fs-6">

                                Inactive

                            </span>
                        }

                    </div>

                </div>

            </div>


            <div class="mb-4">

                <label class="fw-bold text-primary">

                    Description

                </label>

                <p class="mt-2">

                    @(string.IsNullOrWhiteSpace(Model.Description)
                        ? "No description available."
                        : Model.Description)

                </p>

            </div>


            <hr />


            <div class="card shadow-sm border-0 rounded-4">

                <div class="card-header bg-dark text-white">

                    <h5 class="mb-0">

                        <i class="bi bi-bar-chart-fill"></i>

                        Employee Statistics

                    </h5>

                </div>


                <div class="card-body">

                    <div class="row text-center">


                        <div class="col-md-3">

                            <h2 class="fw-bold text-primary">

                                @totalEmployees

                            </h2>

                            <p class="text-muted">

                                Total Employees

                            </p>

                        </div>


                        <div class="col-md-3">

                            <h2 class="fw-bold text-success">

                                @activeEmployees

                            </h2>

                            <p class="text-muted">

                                Active Employees

                            </p>

                        </div>


                        <div class="col-md-3">

                            <h2 class="fw-bold text-danger">

                                @inactiveEmployees

                            </h2>

                            <p class="text-muted">

                                Inactive Employees

                            </p>

                        </div>


                        <div class="col-md-3">

                            <h2 class="fw-bold text-warning">

                                @(Model.Department?.DepartmentName ?? "-")

                            </h2>

                            <p class="text-muted">

                                Department

                            </p>

                        </div>


                    </div>

                </div>

            </div>


            <div class="mt-4 d-flex justify-content-end">


                    @if (await PermissionService.HasPermissionAsync("Designation.Edit"))
                    {
                        <a asp-action="Edit"
                           asp-route-id="@Model.DesignationId"
                           class="btn btn-warning me-3">

                            <i class="bi bi-pencil-square"></i>

                            Edit

                        </a>
                    }


                <a asp-action="Index"
                   class="btn btn-secondary">

                    <i class="bi bi-arrow-left-circle"></i>

                    Back

                </a>


            </div>


        </div>

    </div>

</div>
}
else
{
    <div class="alert alert-danger mt-4">
        You don't have permission to view designation details.
    </div>
}