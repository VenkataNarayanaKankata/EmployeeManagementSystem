@model IEnumerable<EmployeeManagementSystem.ViewModels.DesignationViewModel>

@{
    ViewData["Title"] = "Designation Management";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center flex-wrap mb-4">

        <div>

            <h1 class="fw-bold text-primary">

                <i class="bi bi-person-badge-fill"></i>

                Designation Management

            </h1>

            <p class="text-muted fs-5">

                Manage designations across all departments.

            </p>

        </div>

        @if (User.IsInRole("Admin") || User.IsInRole("HR"))
        {
            <a asp-action="Create"
               class="btn btn-primary btn-lg">

                <i class="bi bi-plus-circle"></i>

                Add Designation

            </a>
        }

    </div>

    <div class="row g-4 mb-4">

        <div class="col-xl-3 col-md-6">

            <div class="card shadow-sm border-0 rounded-4">

                <div class="card-body">

                    <h5 class="text-muted">

                        Total Designations

                    </h5>

                    <h1 class="fw-bold text-primary">

                        @ViewBag.TotalDesignations

                    </h1>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card shadow-sm border-0 rounded-4">

                <div class="card-body">

                    <h5 class="text-muted">

                        Active

                    </h5>

                    <h1 class="fw-bold text-success">

                        @ViewBag.ActiveDesignations

                    </h1>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card shadow-sm border-0 rounded-4">

                <div class="card-body">

                    <h5 class="text-muted">

                        Inactive

                    </h5>

                    <h1 class="fw-bold text-danger">

                        @ViewBag.InactiveDesignations

                    </h1>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card shadow-sm border-0 rounded-4">

                <div class="card-body">

                    <h5 class="text-muted">

                        Employees

                    </h5>

                    <h1 class="fw-bold text-warning">

                        @ViewBag.TotalEmployees

                    </h1>

                </div>

            </div>

        </div>

    </div>
    <div class="card shadow-sm border-0 rounded-4 mb-4">

        <div class="card-header bg-primary text-white">

            <h5 class="mb-0">

                <i class="bi bi-search"></i>

                Search & Filter

            </h5>

        </div>

        <div class="card-body">

            <form asp-action="Index" method="get">

                <div class="row align-items-end">

                    <div class="col-lg-4">

                        <label class="form-label fw-semibold">

                            Search

                        </label>

                        <input type="text"
                               name="search"
                               value="@ViewBag.Search"
                               class="form-control form-control-lg"
                               placeholder="Code, Name or Description..." />

                    </div>

                    <div class="col-lg-3">

                        <label class="form-label fw-semibold">

                            Department

                        </label>

                        <select name="departmentId"
                                asp-items="ViewBag.Departments"
                                class="form-select form-select-lg">

                            <option value="">All Departments</option>

                        </select>

                    </div>

                    <div class="col-lg-2">

                        <label class="form-label fw-semibold">

                            Status

                        </label>

                        <select name="status"
                                class="form-select form-select-lg">

                            <option value="">All</option>

                            @if (ViewBag.Status?.ToString() == "true")
                            {
                                <option value="true" selected>Active</option>
                            }
                            else
                            {
                                <option value="true">Active</option>
                            }

                            @if (ViewBag.Status?.ToString() == "false")
                            {
                                <option value="false" selected>Inactive</option>
                            }
                            else
                            {
                                <option value="false">Inactive</option>
                            }

                        </select>

                    </div>

                    <div class="col-lg-3">

                        <div class="d-grid gap-2">

                            <button type="submit"
                                    class="btn btn-primary btn-lg">

                                <i class="bi bi-search"></i>

                                Search

                            </button>

                            <a asp-action="Index"
                               class="btn btn-secondary">

                                <i class="bi bi-arrow-clockwise"></i>

                                Reset

                            </a>

                        </div>

                    </div>

                </div>

            </form>

        </div>

    </div>
    <div class="card shadow-sm border-0 rounded-4">

        <div class="card-header bg-primary text-white">

            <h5 class="mb-0">

                <i class="bi bi-list-ul"></i>

                Designation List

            </h5>

        </div>

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">

                        <tr>

                            <th>S.No</th>

                            <th>Code</th>

                            <th>Designation</th>

                            <th>Department</th>

                            <th>Employees</th>

                            <th>Status</th>

                            <th class="text-center">Actions</th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.Any())
                        {
                            int sno = 1;

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>@sno</td>

                                    <td>

                                        <span class="fw-semibold">

                                            @item.DesignationCode

                                        </span>

                                    </td>

                                    <td>

                                        @item.DesignationName

                                    </td>

                                    <td>

                                        <span class="badge bg-secondary">

                                            @item.DepartmentName

                                        </span>

                                    </td>

                                    <td>

                                        <span class="badge bg-info">

                                            @item.EmployeeCount

                                        </span>

                                    </td>

                                    <td>

                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">

                                                Active

                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">

                                                Inactive

                                            </span>
                                        }

                                    </td>

                                    <td class="text-center">

                                        <a asp-action="Details"
                                           asp-route-id="@item.DesignationId"
                                           class="btn btn-sm btn-info text-white">

                                            <i class="bi bi-eye"></i>

                                            View

                                        </a>

                                        @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                                        {
                                            <a asp-action="Edit"
                                               asp-route-id="@item.DesignationId"
                                               class="btn btn-sm btn-warning">

                                                <i class="bi bi-pencil-square"></i>

                                                Edit

                                            </a>
                                        }

                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Delete"
                                               asp-route-id="@item.DesignationId"
                                               class="btn btn-sm btn-danger">

                                                <i class="bi bi-trash"></i>

                                                Delete

                                            </a>
                                        }

                                    </td>

                                </tr>

                                sno++;
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="7" class="text-center py-5">

                                    <i class="bi bi-person-badge display-1 text-secondary"></i>

                                    <h4 class="mt-3">

                                        No Designations Found

                                    </h4>

                                    <p class="text-muted">

                                        Click <strong>Add Designation</strong> to create your first designation.

                                    </p>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>