@model EmployeeManagementSystem.ViewModels.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>

<head>

    <meta charset="utf-8" />

    <title>Employee Management System</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <style>

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                background: linear-gradient(135deg,#0d6efd,#3b82f6,#7c3aed);
                font-family: 'Segoe UI';
                overflow: hidden;
            }

                body::before {
                    content: "";
                    position: absolute;
                    width: 500px;
                    height: 500px;
                    background: rgba(255,255,255,.08);
                    border-radius: 50%;
                    top: -120px;
                    left: -120px;
                }

                body::after {
                    content: "";
                    position: absolute;
                    width: 450px;
                    height: 450px;
                    background: rgba(255,255,255,.08);
                    border-radius: 50%;
                    bottom: -120px;
                    right: -120px;
                }

            .login-card {
                width: 430px;
                background: rgba(255,255,255,.15);
                backdrop-filter: blur(18px);
                border-radius: 20px;
                padding: 45px;
                box-shadow: 0 25px 60px rgba(0,0,0,.35);
                border: 1px solid rgba(255,255,255,.2);
                color: white;
                animation: fadeUp 1s;
            }

            @@keyframes fadeUp {

                from {
                    opacity: 0;
                    transform: translateY(60px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .logo {
                width: 90px;
                height: 90px;
                margin: auto;
                border-radius: 50%;
                background: white;
                display: flex;
                justify-content: center;
                align-items: center;
                color: #0d6efd;
                font-size: 40px;
                margin-bottom: 20px;
            }

            h2 {
                text-align: center;
                font-weight: bold;
                margin-bottom: 5px;
            }

            .subtitle {
                text-align: center;
                opacity: .9;
                margin-bottom: 35px;
            }

            .form-control {
                height: 55px;
                border-radius: 12px;
                border: none;
                padding-left: 45px;
                transition: .3s;
            }

                .form-control:focus {
                    transform: scale(1.02);
                    box-shadow: 0 0 15px rgba(255,255,255,.5);
                }

            .input-group {
                position: relative;
                margin-bottom: 20px;
            }

                .input-group i {
                    position: absolute;
                    top: 18px;
                    left: 15px;
                    color: #555;
                    z-index: 10;
                }

            .btn-login {
                width: 100%;
                height: 55px;
                border-radius: 12px;
                border: none;
                background: white;
                color: #0d6efd;
                font-size: 20px;
                font-weight: bold;
                transition: .3s;
            }

                .btn-login:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 12px 30px rgba(0,0,0,.3);
                }

            .validation-summary-errors {
                color: #ffdede;
                margin-bottom: 15px;
            }

            .footer {
                text-align: center;
                margin-top: 25px;
                opacity: .8;
                font-size: 14px;
            }

    </style>

</head>

<body>

    <div class="login-card">

        <div class="logo">

            <i class="fa-solid fa-building"></i>

        </div>

        <h2>Employee Management</h2>

        <div class="subtitle">

            Administrator Login

        </div>

        <form asp-action="Login">

            <div asp-validation-summary="ModelOnly" class="text-warning"></div>

            <div class="input-group">

                <i class="fa-solid fa-user"></i>

                <input asp-for="Username"
                       class="form-control"
                       placeholder="Username">

            </div>

            <span asp-validation-for="Username"
                  class="text-warning"></span>

            <div class="input-group">

                <i class="fa-solid fa-lock"></i>

                <input asp-for="Password"
                       class="form-control"
                       placeholder="Password">

            </div>

            <span asp-validation-for="Password"
                  class="text-warning"></span>

            <button class="btn btn-login mt-3">

                <i class="fa-solid fa-right-to-bracket"></i>

                Login

            </button>

        </form>

        <div class="footer">

            © 2026 Employee Management System

        </div>

    </div>

</body>

</html>