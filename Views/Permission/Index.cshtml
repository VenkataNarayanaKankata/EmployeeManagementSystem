@model EmployeeManagementSystem.ViewModels.PermissionViewModel

@{
    ViewData["Title"] = "Permission Management";
}

@if(await PermissionService.HasPermissionAsync("Permission.View"))
{
<div class="container mt-4">


    <div class="employee-header mb-4">


        <div class="employee-header-left">

            <h1>
                🔑 Permission Management
            </h1>


            <p>
                Manage system permissions and module access.
            </p>


        </div>



        <div class="employee-header-right">


                @if (await PermissionService.HasPermissionAsync("Permission.Create"))
                {
                    <a asp-action="Create"
                       class="btn btn-primary">

                        ➕ Add Permission

                    </a>
                }


        </div>


    </div>





    <div class="row g-4 mb-4">


        <div class="col-md-4">


            <div class="card shadow-sm border-0">


                <div class="card-body">


                    <h6 class="text-muted">
                        Total Permissions
                    </h6>


                    <h2 class="fw-bold text-primary">

                        @Model.TotalPermissions

                    </h2>


                </div>


            </div>


        </div>




        <div class="col-md-4">


            <div class="card shadow-sm border-0">


                <div class="card-body">


                    <h6 class="text-muted">
                        Active Permissions
                    </h6>


                    <h2 class="fw-bold text-success">

                        @Model.ActivePermissions

                    </h2>


                </div>


            </div>


        </div>




        <div class="col-md-4">


            <div class="card shadow-sm border-0">


                <div class="card-body">


                    <h6 class="text-muted">
                        Inactive Permissions
                    </h6>


                    <h2 class="fw-bold text-danger">

                        @Model.InactivePermissions

                    </h2>


                </div>


            </div>


        </div>


    </div>






    <div class="card shadow-sm border-0 mb-4">


        <div class="card-header bg-primary text-white">

            <h5 class="mb-0">

                🔍 Search & Filter

            </h5>


        </div>




        <div class="card-body">


            <form method="get"
                  asp-action="Index">


                <div class="row g-3 align-items-end">


                    <div class="col-md-5">


                        <label class="form-label">

                            Permission Name

                        </label>


                        <input type="text"
                               name="search"
                               value="@Model.Search"
                               class="form-control"
                               placeholder="Search permission..." />


                    </div>





                    <div class="col-md-4">


                        <label class="form-label">

                            Module

                        </label>


                        <select name="module"
                                class="form-select">


                            <option value="">
                                All Modules
                            </option>


                            @foreach (var module in Model.Modules)
                            {

                                <option value="@module"
                                        selected="@(Model.Module == module)">

                                    @module

                                </option>

                            }


                        </select>


                    </div>





                    <div class="col-md-3">


                        <button class="btn btn-primary">

                            🔍 Search

                        </button>


                        <a asp-action="Index"
                           class="btn btn-secondary ms-2">

                            🔄 Reset

                        </a>


                    </div>


                </div>


            </form>


        </div>


    </div>







    <div class="card shadow-sm border-0">


        <div class="card-header bg-white">


            <h4 class="fw-bold text-primary mb-0">

                🔐 Permission List

            </h4>


        </div>




        <div class="table-responsive">


            <table class="table table-striped table-bordered mb-0">


                <thead class="table-primary">


                    <tr>

                        <th>
                            Permission
                        </th>


                        <th>
                            Module
                        </th>


                        <th>
                            Description
                        </th>


                        <th>
                            Status
                        </th>


                        <th width="250">
                            Actions
                        </th>


                    </tr>


                </thead>



                <tbody>



                    @if (Model.Permissions.Any())
                    {


                        foreach (var item in Model.Permissions)
                        {


                            <tr>


                                <td class="fw-bold">

                                    @item.PermissionName

                                </td>



                                <td>

                                    <span class="badge bg-primary">

                                        @item.ModuleName

                                    </span>

                                </td>



                                <td>

                                    @item.Description

                                </td>



                                <td>


                                    @if (item.IsActive)
                                    {

                                        <span class="badge bg-success">
                                            Active
                                        </span>

                                    }
                                    else
                                    {

                                        <span class="badge bg-danger">
                                            Inactive
                                        </span>

                                    }


                                </td>



                                <td>


                                        @if (await PermissionService.HasPermissionAsync("Permission.View"))
                                        {
                                            <a asp-action="Details"
                                               asp-route-id="@item.PermissionId"
                                               class="btn btn-info btn-sm text-white">

                                                Details

                                            </a>
                                        }



                                        @if (await PermissionService.HasPermissionAsync("Permission.Edit"))
                                        {
                                            <a asp-action="Edit"
                                               asp-route-id="@item.PermissionId"
                                               class="btn btn-warning btn-sm">

                                                Edit

                                            </a>
                                        }



                                        @if (await PermissionService.HasPermissionAsync("Permission.Delete"))
                                        {
                                            <a asp-action="Delete"
                                               asp-route-id="@item.PermissionId"
                                               class="btn btn-danger btn-sm">

                                                Delete

                                            </a>
                                        }


                                </td>



                            </tr>


                        }


                    }
                    else
                    {


                        <tr>


                            <td colspan="5"
                                class="text-center py-4">


                                <h5 class="text-muted">

                                    No Permissions Found

                                </h5>


                            </td>


                        </tr>


                    }



                </tbody>


            </table>


        </div>


    </div>



</div>
}
else
{
    <div class="alert alert-danger">
        You don't have permission to view permissions.
    </div>
}