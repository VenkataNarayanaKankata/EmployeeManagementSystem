@model EmployeeManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Edit Employee";
}

<div class="container py-4">

    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-header bg-primary text-white rounded-top-4 py-3">
            <h2 class="mb-0">
                ✏️ Edit Employee
            </h2>
        </div>

        <div class="card-body p-4">

            <form asp-action="Edit" enctype="multipart/form-data">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="EmployeeId" />
                <input type="hidden" asp-for="PhotoPath" />

                <div class="row">

                    <!-- LEFT SIDE -->
                    <div class="col-md-4 text-center">

                        @if (!string.IsNullOrEmpty(Model.PhotoPath))
                        {
                            <img src="~/uploads/@Model.PhotoPath"
                                 class="img-fluid rounded shadow"
                                 style="width:250px;height:250px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="border rounded shadow d-flex justify-content-center align-items-center"
                                 style="width:250px;height:250px;margin:auto;">
                                <span class="text-muted">
                                    No Photo
                                </span>
                            </div>
                        }

                        <div class="mt-4">

                            <label class="fw-bold mb-2">
                                Upload New Photo
                            </label>

                            <input type="file"
                                   name="PhotoFile"
                                   class="form-control" />

                        </div>

                    </div>

                    <!-- RIGHT SIDE -->

                    <div class="col-md-8">

                        <div class="row">

                            <div class="col-md-6 mb-3">
                                <label asp-for="FirstName" class="form-label fw-semibold"></label>
                                <input asp-for="FirstName" class="form-control" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="LastName" class="form-label fw-semibold"></label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>

                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label fw-semibold"></label>
                            <input asp-for="Phone" class="form-control" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
    <label asp-for="Gender" class="form-label"></label>
    <select asp-for="Gender" class="form-select">
        <option value="">-- Select Gender --</option>
        <option value="Male">Male</option>
        <option value="Female">Female</option>
        <option value="Other">Other</option>
    </select>
    <span asp-validation-for="Gender" class="text-danger"></span>
</div>

                        <div class="row">

                            <div class="col-md-6 mb-3">
                                <label asp-for="Salary" class="form-label fw-semibold"></label>
                                <input asp-for="Salary" class="form-control" />
                                <span asp-validation-for="Salary" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="JoiningDate" class="form-label fw-semibold"></label>
                                <input asp-for="JoiningDate" class="form-control" />
                                <span asp-validation-for="JoiningDate" class="text-danger"></span>
                            </div>

                        </div>

                        <div class="mb-3">
                            <label asp-for="DepartmentId" class="form-label fw-semibold"></label>

                            <select asp-for="DepartmentId"
                                    asp-items="ViewBag.DepartmentId"
                                    class="form-select">
                                <option value="">-- Select Department --</option>
                            </select>

                            <span asp-validation-for="DepartmentId" class="text-danger"></span>

                        </div>

                    </div>
                    <div class="mb-3">
    <label asp-for="RoleId" class="form-label fw-semibold">
        Role
    </label>

    <select asp-for="RoleId"
            asp-items="ViewBag.RoleId"
            class="form-select">

        <option value="">-- Select Role --</option>

    </select>

    <span asp-validation-for="RoleId"
          class="text-danger"></span>
</div>

                </div>


                <div class="mt-5 d-flex justify-content-end">

                    <button type="submit" class="btn btn-success px-4 me-2">
                        💾 Save Changes
                    </button>

                    <a asp-action="Index" class="btn btn-secondary px-4">
                        ↩ Back
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}