@model EmployeeManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Employee Profile";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0 rounded-4">


        <div class="card-header bg-primary text-white py-3">

            <h2 class="mb-0">
                👤 Employee Profile
            </h2>

        </div>


        <div class="card-body p-4">


            <div class="row">



                <div class="col-lg-4 text-center border-end">


                    @if (!string.IsNullOrEmpty(Model.PhotoPath))
                    {
                        <img src="~/uploads/@Model.PhotoPath"
                             class="rounded-circle shadow mb-3"
                             style="width:220px;
                        height:220px;
                        object-fit:cover;
                        border:6px solid #0d6efd;" />
                    }
                    else
                    {
                        <div class="rounded-circle border shadow d-flex justify-content-center align-items-center mx-auto"
                             style="width:220px;
                            height:220px;
                            font-size:22px;
                            background:#f8f9fa;">

                            👤

                        </div>
                    }



                    <h3 class="mt-3 mb-1">

                        @Model.FirstName @Model.LastName

                    </h3>


                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success fs-6">
                            Active Employee
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger fs-6">
                            Inactive Employee
                        </span>
                    }



                    <div class="mt-3">


                        <span class="badge bg-primary fs-6">

                            @Model.Designation?.DesignationName

                        </span>


                    </div>


                </div>




                <div class="col-lg-8">


                    <div class="row">



                        <div class="col-md-6 mb-4">

                            <label class="text-muted">
                                Employee Code
                            </label>

                            <h5>

                                <span class="badge bg-dark fs-6">

                                    @Model.EmployeeCode

                                </span>

                            </h5>

                        </div>




                        <div class="col-md-6 mb-4">

                            <label class="text-muted">
                                Full Name
                            </label>

                            <h5>
                                @Model.FirstName @Model.LastName
                            </h5>

                        </div>




                        <div class="col-md-6 mb-4">

                            <label class="text-muted">
                                Email
                            </label>

                            <h5>
                                @Model.Email
                            </h5>

                        </div>




                        <div class="col-md-6 mb-4">

                            <label class="text-muted">
                                Phone
                            </label>

                            <h5>
                                @Model.Phone
                            </h5>

                        </div>




                        <div class="col-md-6 mb-4">

                            <label class="text-muted">
                                Gender
                            </label>

                            <h5>

                                <span class="badge bg-secondary fs-6">

                                    @Model.Gender

                                </span>

                            </h5>

                        </div>




                        <div class="col-md-6 mb-4">

                            <label class="text-muted">
                                Salary
                            </label>

                            <h5 class="text-success fw-bold">

                                ₹ @Model.Salary.ToString("N0") / Month

                            </h5>

                        </div>




                        <div class="col-md-6 mb-4">

                            <label class="text-muted">
                                Joining Date
                            </label>

                            <h5>

                                @Model.JoiningDate.ToString("dd MMM yyyy")

                            </h5>

                        </div>




                        <div class="col-md-6 mb-4">

                            <label class="text-muted">
                                Branch
                            </label>

                            <h5>

                                <span class="badge bg-dark fs-6">

                                    @Model.Branch?.BranchName

                                </span>

                            </h5>

                        </div>




                        <div class="col-md-6 mb-4">

                            <label class="text-muted">
                                Department
                            </label>

                            <h5>

                                <span class="badge bg-primary fs-6">

                                    @Model.Department?.DepartmentName

                                </span>

                            </h5>

                        </div>




                        <div class="col-md-6 mb-4">

                            <label class="text-muted">
                                Designation
                            </label>

                            <h5>

                                <span class="badge bg-info text-dark fs-6">

                                    @Model.Designation?.DesignationName

                                </span>

                            </h5>

                        </div>




                        <div class="col-md-6 mb-4">

                            <label class="text-muted">
                                Role
                            </label>

                            <h5>

                                <span class="badge bg-success fs-6">

                                    @Model.Role?.RoleName

                                </span>

                            </h5>

                        </div>




                        <div class="col-md-6 mb-4">

                            <label class="text-muted">
                                Status
                            </label>

                            <h5>

                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Inactive
                                    </span>
                                }

                            </h5>

                        </div>



                    </div>



                    <hr />



                    <div class="d-flex gap-2">


                        @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                        {
                            <a asp-action="Edit"
                               asp-route-id="@Model.EmployeeId"
                               class="btn btn-warning">

                                ✏ Edit Employee

                            </a>
                        }


                        <a asp-action="Index"
                           class="btn btn-secondary">

                            📋 Employee List

                        </a>


                        <button class="btn btn-info"
                                onclick="window.print();">

                            🖨 Print

                        </button>


                    </div>


                </div>


            </div>


        </div>


    </div>


</div>