@model EmployeeManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Employee Details";
}

<div class="container mt-4">

    <div class="card shadow-lg">

        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Employee Details</h3>
        </div>

        <div class="card-body">

            <div class="row">

                <!-- Employee Photo -->
                <div class="col-md-4 text-center">

                    @if (!string.IsNullOrEmpty(Model.PhotoPath))
                    {
                        <img src="~/uploads/@Model.PhotoPath"
                             alt="Employee Photo"
                             class="img-thumbnail shadow"
                             style="width:250px; height:250px; object-fit:cover;" />
                    }
                    else
                    {
                        <div class="border d-flex justify-content-center align-items-center shadow"
                             style="width:250px;height:250px;">
                            <span>No Photo</span>
                        </div>
                    }

                </div>

                <!-- Employee Information -->
                <div class="col-md-8">

                    <table class="table table-bordered table-striped">

                        <tr>
                            <th width="35%">Employee ID</th>
                            <td>@Model.EmployeeId</td>
                        </tr>

                        <tr>
                            <th>First Name</th>
                            <td>@Model.FirstName</td>
                        </tr>

                        <tr>
                            <th>Last Name</th>
                            <td>@Model.LastName</td>
                        </tr>

                        <tr>
                            <th>Email</th>
                            <td>@Model.Email</td>
                        </tr>

                        <tr>
                            <th>Phone</th>
                            <td>@Model.Phone</td>
                        </tr>

                        <tr>
                            <th>Salary</th>
                            <td>₹ @Model.Salary</td>
                        </tr>

                        <tr>
                            <th>Joining Date</th>
                            <td>@Model.JoiningDate.ToString("dd-MMM-yyyy")</td>
                        </tr>

                        <tr>
                            <th>Department</th>
                            <td>@Model.Department?.DepartmentName</td>
                        </tr>

                    </table>

                </div>

            </div>

        </div>

        <div class="card-footer text-end">

            <a asp-action="Edit"
               asp-route-id="@Model.EmployeeId"
               class="btn btn-warning">
                Edit
            </a>

            <a asp-action="Index"
               class="btn btn-secondary">
                Back to List
            </a>

        </div>

    </div>

</div>