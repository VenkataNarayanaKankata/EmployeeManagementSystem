@model EmployeeManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Employee Profile";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-primary text-white py-3">

            <h2 class="mb-0">
                👤 Employee Profile
            </h2>

        </div>

        <div class="card-body p-4">

            <div class="row">

                <!-- Employee Photo -->
                <div class="col-lg-4 text-center border-end">

                    @if (!string.IsNullOrEmpty(Model.PhotoPath))
                    {
                        <img src="~/uploads/@Model.PhotoPath"
                             class="rounded-circle shadow mb-3"
                             style="width:220px;
                        height:220px;
                        object-fit:cover;
                        border:6px solid #0d6efd;" />
                    }
                    else
                    {
                        <div class="rounded-circle border shadow d-flex justify-content-center align-items-center mx-auto"
                             style="width:220px;
                            height:220px;
                            font-size:22px;
                            background:#f8f9fa;">

                            👤

                        </div>
                    }

                    <h3 class="mt-3 mb-1">

                        @Model.FirstName @Model.LastName

                    </h3>

                    <span class="badge bg-success fs-6">

                        Active Employee

                    </span>

                    <div class="mt-3">

                        <span class="badge bg-primary fs-6">

                            @Model.Department?.DepartmentName

                        </span>

                    </div>

                </div>

                <!-- Employee Information -->
                <div class="col-lg-8">

                    <div class="row">

                        <div class="col-md-6 mb-4">
                            <label class="text-muted">Employee ID</label>
                            <h5>@Model.EmployeeId</h5>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="text-muted">Email</label>
                            <h5>@Model.Email</h5>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="text-muted">Phone</label>
                            <h5>@Model.Phone</h5>
                        </div>
                        <div class="row mb-3">
    <div class="col-md-3 fw-bold">
        Gender
    </div>
    <div class="col-md-9">
        @Model.Gender
    </div>
</div>
                        <div class="col-md-6 mb-4">
                            <label class="text-muted">Salary</label>
                            <h5 class="text-success">
                                ₹ @Model.Salary.ToString("N0")
                            </h5>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="text-muted">Joining Date</label>
                            <h5>
                                @Model.JoiningDate.ToString("dd MMM yyyy")
                            </h5>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="text-muted">Department</label>
                            <h5>
                                @Model.Department?.DepartmentName
                            </h5>
                        </div>
                        <div class="row mb-3">
    <div class="col-md-3 fw-bold">
        Role
    </div>
    <div class="col-md-9">
        @Model.Role?.RoleName
    </div>
</div>

                    </div>

                    <hr />

                    <div class="d-flex gap-2">

                        <a asp-action="Edit"
                           asp-route-id="@Model.EmployeeId"
                           class="btn btn-warning">

                            ✏ Edit Employee

                        </a>

                        <a asp-action="Index"
                           class="btn btn-secondary">

                            ← Back

                        </a>

                        <button class="btn btn-info"
                                onclick="window.print();">

                            🖨 Print

                        </button>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>