@model IEnumerable<EmployeeManagementSystem.Models.Employee>

@{
    ViewData["Title"] = "Recycle Bin";
}

<div class="container mt-4">


    <div class="d-flex justify-content-between align-items-center mb-4">


        <div>

            <h2 class="fw-bold text-danger">

                🗑️ Employee Recycle Bin

            </h2>


            <p class="text-muted">

                Restore deleted employees or permanently remove them.

            </p>


        </div>



        <a asp-action="Index"
           class="btn btn-primary">

            ← Back to Employees

        </a>


    </div>




    <div class="card shadow">


        <div class="card-header bg-white border-bottom py-3">


            <div class="d-flex justify-content-between align-items-center">


                <h4 class="mb-0 fw-bold text-danger">

                    <i class="bi bi-trash3-fill me-2"></i>

                    Deleted Employees

                </h4>



                <span class="badge bg-danger fs-6">

                    Total : @Model.Count()

                </span>


            </div>


        </div>




        <div class="table-responsive">


            <table class="table table-striped table-bordered mb-0">


                <thead class="table-danger">


                    <tr>

                        <th>Photo</th>

                        <th>Employee Code</th>

                        <th>Name</th>

                        <th>Email</th>

                        <th>Branch</th>

                        <th>Department</th>

                        <th>Designation</th>

                        <th>Role</th>

                        <th width="240">
                            Actions
                        </th>


                    </tr>


                </thead>



                <tbody>



                    @if (Model.Any())
                    {

                        foreach (var item in Model)
                        {

                            <tr>


                                <td>


                                    @if (!string.IsNullOrEmpty(item.PhotoPath))
                                    {

                                        <img src="~/uploads/@item.PhotoPath"
                                             width="60"
                                             height="60"
                                             class="rounded-circle border border-2 border-danger"
                                             style="object-fit:cover;" />

                                    }
                                    else
                                    {

                                        <span class="text-muted">
                                            No Photo
                                        </span>

                                    }


                                </td>




                                <td>

                                    <span class="badge bg-dark">

                                        @item.EmployeeCode

                                    </span>

                                </td>




                                <td>

                                    @item.FirstName @item.LastName

                                </td>




                                <td>

                                    @item.Email

                                </td>




                                <td>

                                    <span class="badge bg-dark">

                                        @item.Branch?.BranchName

                                    </span>

                                </td>




                                <td>

                                    <span class="badge bg-primary">

                                        @item.Department?.DepartmentName

                                    </span>

                                </td>




                                <td>

                                    <span class="badge bg-info text-dark">

                                        @item.Designation?.DesignationName

                                    </span>

                                </td>




                                <td>

                                    <span class="badge bg-success">

                                        @item.Role?.RoleName

                                    </span>

                                </td>




                                <td>


                                    @if (await PermissionService.HasPermissionAsync("Employee.Restore"))
                                    {
                                        <form asp-action="Restore"
                                              asp-route-id="@item.EmployeeId"
                                              method="post"
                                              class="d-inline">

                                            <button class="btn btn-success btn-sm"
                                                    onclick="return confirm('Restore this employee?');">

                                                <i class="bi bi-arrow-counterclockwise"></i>

                                                Restore

                                            </button>

                                        </form>
                                    }

                                    @if (await PermissionService.HasPermissionAsync("Employee.Delete"))
                                    {
                                        <form asp-action="PermanentDelete"
                                              asp-route-id="@item.EmployeeId"
                                              method="post"
                                              class="d-inline">

                                            <button class="btn btn-danger btn-sm"
                                                    onclick="return confirm('Are you sure you want to permanently delete this employee? This action cannot be undone.');">

                                                <i class="bi bi-trash3-fill"></i>

                                                Delete Forever

                                            </button>

                                        </form>
                                    }


                                </td>


                            </tr>

                        }

                    }
                    else
                    {

                        <tr>


                            <td colspan="9"
                                class="text-center py-4">


                                <h4 class="text-success">


                                    <i class="bi bi-check-circle-fill"></i>


                                    Recycle Bin is Empty


                                </h4>


                                <p class="text-muted">

                                    Deleted employees will appear here.

                                </p>


                            </td>


                        </tr>

                    }


                </tbody>


            </table>


        </div>


    </div>


</div>