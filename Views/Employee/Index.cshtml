@model IEnumerable<EmployeeManagementSystem.Models.Employee>

@{
    ViewData["Title"] = "Employee Management";
}

<div class="container mt-4">

    <!--==========================================================
    PAGE HEADER
===========================================================-->

    <div class="employee-header mb-4">

        <div class="employee-header-left">

            <h1>
                👨‍💼 Employee Management
            </h1>

            <p>
                Manage employee records, import/export data and perform employee operations.
            </p>

        </div>

        <div class="employee-header-right">

            <a asp-action="ExportToExcel" class="btn btn-success">
                📊 Export Excel
            </a>

            <a asp-action="ExportToPdf" class="btn btn-danger">
                📄 Export PDF
            </a>

            <a asp-controller="Import"
               asp-action="EmployeeImport"
               class="btn btn-success">
                📥 Import Excel
            </a>

            <a asp-action="Create"
               class="btn btn-primary">
                ➕ Add Employee
            </a>

            <a asp-action="RecycleBin"
               class="btn btn-outline-danger">
                🗑 Recycle Bin
            </a>

        </div>

    </div>

    <!-- Search Card -->
    <div class="card shadow-sm mb-4">

        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                🔍 Search & Filter
            </h5>
        </div>

        <div class="card-body">

            <form asp-action="Index" method="get">

                <div class="row g-3 align-items-end">

                    <div class="col-md-5">

                        <label class="form-label">
                            Employee Name
                        </label>

                        <input type="text"
                               name="searchString"
                               class="form-control"
                               value="@Context.Request.Query["searchString"]"
                               placeholder="Search Employee..." />

                    </div>

                    <div class="col-md-3">

                        <label class="form-label">
                            Department
                        </label>

                        <select name="departmentId"
                                asp-items="ViewBag.DepartmentId"
                                class="form-select">

                            <option value="">
                                All Departments
                            </option>

                        </select>

                    </div>

                    <div class="col-md-4">

                        <button type="submit"
                                class="btn btn-primary me-2">
                            🔍 Search
                        </button>

                        <button type="submit"
                                class="btn btn-success me-2">
                            📂 Filter
                        </button>

                        <a asp-action="Index"
                           class="btn btn-secondary">
                            🔄 Reset
                        </a>

                    </div>

                </div>

            </form>

        </div>

    </div>

    <!-- Employee Table -->

    <div class="card shadow-sm">

        <div class="card-header bg-dark text-white">

            <h5 class="mb-0">
                Employee List
            </h5>

        </div>

        <div class="table-responsive">

            <table class="table table-striped table-bordered align-middle mb-0">

                <thead class="table-primary">

                    <tr>

                        <th>Photo</th>
                        <th>Role</th>
                        <th>First Name</th>
                        <th>Last Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Gender</th>
                        <th>Salary</th>
                        <th>Joining Date</th>
                        <th>Department</th>
                        <th style="width:240px;">Actions</th>

                    </tr>

                </thead>

                <tbody>

@if (Model.Any())
{
    foreach (var item in Model)
    {
        <tr>

            <td>

                @if (!string.IsNullOrEmpty(item.PhotoPath))
                {
                    <img src="~/uploads/@item.PhotoPath"
                         style="width:60px;
                                height:60px;
                                object-fit:cover;
                                border-radius:50%;
                                border:2px solid #0d6efd;" />
                }
                else
                {
                    <span class="text-muted">
                        No Photo
                    </span>
                }

            </td>
            <td>@item.Role?.RoleName</td>

            <td>@item.FirstName</td>

            <td>@item.LastName</td>

            <td>@item.Email</td>

            <td>@item.Phone</td>
            <td>@item.Gender</td>

            <td>
                ₹ @item.Salary.ToString("N0")
            </td>

            <td>
                @item.JoiningDate.ToString("dd MMM yyyy")
            </td>

            <td>

                <span class="badge bg-primary">
                    @item.Department?.DepartmentName
                </span>

            </td>

            <td>

                <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Edit"
                                           asp-route-id="@item.EmployeeId"
                                           class="btn btn-warning btn-sm">
                                            Edit
                                        </a>

                                        <a asp-action="Details"
                                           asp-route-id="@item.EmployeeId"
                                           class="btn btn-info btn-sm text-white">
                                            Details
                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@item.EmployeeId"
                                           class="btn btn-danger btn-sm">
                                             Delete
                                        </a>

                                    </div>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="9" class="text-center py-5">

                                <h5 class="text-muted">
                                    No Employees Found
                                </h5>

                                <p class="text-muted">
                                    Click "Add Employee" to create your first employee.
                                </p>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
