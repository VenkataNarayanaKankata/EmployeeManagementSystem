@model IEnumerable<EmployeeManagementSystem.Models.Employee>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>
<form asp-action="Index" method="get" class="mb-3">
    <div class="row g-2 align-items-end">

        <!-- Search -->
        <div class="col-md-4">
            <label class="form-label">Search</label>
            <input type="text"
                   name="searchString"
                   class="form-control"
                   value="@Context.Request.Query["searchString"]"
                   placeholder="Search Employee..." />
        </div>

        <!-- Search Button -->
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100">
                Search
            </button>
        </div>

        <!-- Department -->
        <div class="col-md-3">
            <label class="form-label">Department</label>
            <select name="departmentId"
                    asp-items="ViewBag.DepartmentId"
                    class="form-select">
                <option value="">All Departments</option>
            </select>
        </div>

        <!-- Filter Button -->
        <div class="col-md-1">
            <button type="submit" class="btn btn-success w-100">
                Filter
            </button>
        </div>

        <!-- Clear Button -->
        <div class="col-md-1">
            <a asp-action="Index" class="btn btn-secondary w-100">
                Clear
            </a>
        </div>

    </div>
</form>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.FirstName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LastName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Phone)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Salary)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.JoiningDate)
            </th>
            <th>
                Department
            </th>
            <th>Photo</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.FirstName)
            </td>
            <td>
                @Html.DisplayFor(model => item.LastName)
            </td>
            <td>
                @Html.DisplayFor(model => item.Email)
            </td>
            <td>
                @Html.DisplayFor(model => item.Phone)
            </td>
            <td>
                @Html.DisplayFor(model => item.Salary)
            </td>
            <td>
                @Html.DisplayFor(model => item.JoiningDate)
            </td>
                <td>
                    @item.Department?.DepartmentName
                </td>
            <td>
                @if (!string.IsNullOrEmpty(item.PhotoPath))
                {
                    <img src="~/uploads/@item.PhotoPath" alt="Photo" class="img-thumbnail" style="max-width: 100px;" />
                }
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.EmployeeId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.EmployeeId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.EmployeeId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
