@model IEnumerable<EmployeeManagementSystem.Models.Employee>

@{
    ViewData["Title"] = "Employee Management";
}

<div class="container mt-4">

    <div class="employee-header mb-4">

        <div class="employee-header-left">

            <h1>
                👨‍💼 Employee Management
            </h1>

            <p>
                Manage employee records, import/export data and perform employee operations.
            </p>

        </div>


        <div class="employee-header-right">

            @if (User.IsInRole("Admin") || User.IsInRole("HR"))
            {
                <a asp-action="ExportToExcel" class="btn btn-success">
                    📊 Export Excel
                </a>

                <a asp-action="ExportToPdf" class="btn btn-danger">
                    📄 Export PDF
                </a>

                <a asp-controller="Import"
                   asp-action="EmployeeImport"
                   class="btn btn-success">
                    📥 Import Excel
                </a>

                <a asp-action="Create"
                   class="btn btn-primary">
                    ➕ Add Employee
                </a>
            }


            @if (User.IsInRole("Admin"))
            {
                <a asp-action="RecycleBin"
                   class="btn btn-outline-danger">
                    🗑 Recycle Bin
                </a>
            }

        </div>

    </div>


    <div class="card shadow-sm mb-4">

        <div class="card-header bg-primary text-white">

            <h5 class="mb-0">
                🔍 Search & Filter
            </h5>

        </div>


        <div class="card-body">

            <form asp-action="Index" method="get">

                <div class="row g-3 align-items-end">


                    <div class="col-lg-3">

                        <label class="form-label">
                            Search Employee
                        </label>

                        <input type="text"
                               name="searchString"
                               class="form-control"
                               placeholder="Name, Code, Email" />

                    </div>



                    <div class="col-lg-2">

                        <label class="form-label">
                            Branch
                        </label>

                        <select name="branchId"
                                asp-items="ViewBag.BranchId"
                                class="form-select">

                            <option value="">
                                All Branches
                            </option>

                        </select>

                    </div>




                    <div class="col-lg-2">

                        <label class="form-label">
                            Department
                        </label>

                        <select name="departmentId"
                                asp-items="ViewBag.DepartmentId"
                                class="form-select">

                            <option value="">
                                All Departments
                            </option>

                        </select>

                    </div>




                    <div class="col-lg-2">

                        <label class="form-label">
                            Designation
                        </label>

                        <select name="designationId"
                                asp-items="ViewBag.DesignationId"
                                class="form-select">

                            <option value="">
                                All Designations
                            </option>

                        </select>

                    </div>




                    <div class="col-lg-2">

                        <label class="form-label">
                            Role
                        </label>

                        <select name="roleId"
                                asp-items="ViewBag.RoleId"
                                class="form-select">

                            <option value="">
                                All Roles
                            </option>

                        </select>

                    </div>



                    <div class="col-lg-1">

                        <button type="submit"
                                class="btn btn-primary w-100">

                            search

                        </button>

                    </div>


                    <div class="col-lg-2">

                        <a asp-action="Index"
                           class="btn btn-secondary w-100">

                            🔄 Reset

                        </a>

                    </div>


            </form>


        </div>

    </div>



    <div class="card shadow-sm">


        <div class="card-header bg-white border-bottom py-3">


            <div class="d-flex justify-content-between align-items-center">


                <h4 class="mb-0 fw-bold text-primary">

                    <i class="bi bi-people-fill me-2"></i>

                    Employee List

                </h4>


                <span class="badge bg-primary fs-6">

                    Total Employees :
                    @Model.Count()

                </span>


            </div>


        </div>



        <div class="table-responsive">


            <table class="table table-striped table-bordered align-middle mb-0">


                <thead class="table-primary">

                    <tr>

                        <th>Photo</th>
                        <th>Employee Code</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Branch</th>
                        <th>Department</th>
                        <th>Designation</th>
                        <th>Role</th>
                        <th>Salary</th>
                        <th>Joining Date</th>
                        <th>Status</th>
                        <th style="width:240px;">Actions</th>

                    </tr>

                </thead>


                <tbody>


                    @if (Model.Any())
                    {

                        foreach (var item in Model)
                        {

                            <tr>


                                <td>

                                    @if (!string.IsNullOrEmpty(item.PhotoPath))
                                    {
                                        <img src="~/uploads/@item.PhotoPath"
                                             style="width:60px;
                                        height:60px;
                                        object-fit:cover;
                                        border-radius:50%;
                                        border:2px solid #0d6efd;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">
                                            No Photo
                                        </span>
                                    }

                                </td>


                                <td>
                                    @item.EmployeeCode
                                </td>


                                <td>
                                    @item.FirstName @item.LastName
                                </td>


                                <td>
                                    @item.Email
                                </td>


                                <td>
                                    @item.Phone
                                </td>


                                <td>

                                    <span class="badge bg-dark">
                                        @item.Branch?.BranchName
                                    </span>

                                </td>


                                <td>

                                    <span class="badge bg-primary">
                                        @item.Department?.DepartmentName
                                    </span>

                                </td>


                                <td>

                                    <span class="badge bg-info text-dark">
                                        @item.Designation?.DesignationName
                                    </span>

                                </td>


                                <td>

                                    <span class="badge bg-success">
                                        @item.Role?.RoleName
                                    </span>

                                </td>


                                <td>
                                    ₹ @item.Salary.ToString("N0")
                                </td>


                                <td>
                                    @item.JoiningDate.ToString("dd MMM yyyy")
                                </td>


                                <td>

                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            Inactive
                                        </span>
                                    }

                                </td>


                                <td>

                                    <div class="d-flex justify-content-center gap-2">


                                        @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                                        {
                                            <a asp-action="Edit"
                                               asp-route-id="@item.EmployeeId"
                                               class="btn btn-warning btn-sm">

                                                Edit

                                            </a>
                                        }


                                        <a asp-action="Details"
                                           asp-route-id="@item.EmployeeId"
                                           class="btn btn-info btn-sm text-white">

                                            Details

                                        </a>


                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Delete"
                                               asp-route-id="@item.EmployeeId"
                                               class="btn btn-danger btn-sm">

                                                Delete

                                            </a>
                                        }


                                    </div>

                                </td>


                            </tr>

                        }

                    }
                    else
                    {

                        <tr>

                            <td colspan="13"
                                class="text-center py-5">

                                <h5 class="text-muted">
                                    No Employees Found
                                </h5>

                                <p class="text-muted">
                                    Click "Add Employee" to create your first employee.
                                </p>

                            </td>

                        </tr>

                    }


                </tbody>


            </table>


        </div>


    </div>


</div>