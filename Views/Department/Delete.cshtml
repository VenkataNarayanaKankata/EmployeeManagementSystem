@model EmployeeManagementSystem.Models.Department

@{
    ViewData["Title"] = "Delete Department";
}

<div class="container-fluid py-4">

    <div class="card shadow-sm border-0 rounded-4">

        <div class="card-header bg-danger text-white">

            <h3 class="mb-0">

                <i class="bi bi-trash-fill"></i>

                Delete Department

            </h3>

        </div>

        <div class="card-body p-4">

            <div class="alert alert-danger rounded-3">

                <h5>

                    <i class="bi bi-exclamation-triangle-fill"></i>

                    Confirm Deletion

                </h5>

                <p class="mb-0">

                    This action cannot be undone. If employees are assigned to this department, deletion will not be allowed.

                </p>

            </div>

            <div class="row mb-4">

                <div class="col-md-6 mb-4">

                    <label class="fw-bold text-primary">

                        Department Code

                    </label>

                    <h5 class="mt-2">

                        @Model.DepartmentCode

                    </h5>

                </div>

                <div class="col-md-6 mb-4">

                    <label class="fw-bold text-primary">

                        Department Name

                    </label>

                    <h5 class="mt-2">

                        @Model.DepartmentName

                    </h5>

                </div>

            </div>

            <div class="row mb-4">

                <div class="col-md-12">

                    <label class="fw-bold text-primary">

                        Description

                    </label>

                    <p class="mt-2">

                        @(string.IsNullOrWhiteSpace(Model.Description)
                            ? "No description available."
                            : Model.Description)

                    </p>

                </div>

            </div>

            <div class="row mb-4">

                <div class="col-md-6">

                    <label class="fw-bold text-primary">

                        Status

                    </label>

                    <div class="mt-2">

                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success fs-6">

                                Active

                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger fs-6">

                                Inactive

                            </span>
                        }

                    </div>

                </div>

            </div>

            <hr />

            <form asp-action="Delete">

                <input asp-for="DepartmentId" type="hidden" />

                <div class="d-flex justify-content-between">

                    <a asp-action="Index"
                       class="btn btn-secondary btn-lg">

                        <i class="bi bi-arrow-left-circle"></i>

                        Back

                    </a>

                    <button type="submit"
                            class="btn btn-danger btn-lg"
                            onclick="return confirm('Are you sure you want to delete this department?');">

                        <i class="bi bi-trash-fill"></i>

                        Delete Department

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>