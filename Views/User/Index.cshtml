@model EmployeeManagementSystem.ViewModels.UserManagementViewModel

@{
    ViewData["Title"] = "User Management";
}
@if(await PermissionService.HasPermissionAsync("User.View"))
{
<div class="container-fluid py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold">
                <i class="bi bi-person-gear"></i>
                User Management
            </h2>

            <p class="text-muted mb-0">
                Manage system users and roles
            </p>
        </div>

        <div class="d-flex gap-2">

            @if (await PermissionService.HasPermissionAsync("User.Create"))
            {
                <a asp-action="Create"
                   class="btn btn-primary">

                    <i class="bi bi-person-plus-fill"></i>

                    Create User

                </a>
            }

                @if (await PermissionService.HasPermissionAsync("User.Generate"))
            {
                <a asp-action="GenerateUsers"
                   class="btn btn-success">

                    ⚡ Generate User Accounts

                </a>
            }

</div>

    </div>

    <!-- Summary Cards -->

    <div class="row mb-4">

        <div class="col-md-4">

            <div class="card shadow-sm border-0">

                <div class="card-body text-center">

                    <h6 class="text-muted">
                        Total Users
                    </h6>

                    <h2 class="fw-bold text-primary">
                        @Model.TotalUsers
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-sm border-0">

                <div class="card-body text-center">

                    <h6 class="text-muted">
                        Active Users
                    </h6>

                    <h2 class="fw-bold text-success">
                        @Model.ActiveUsers
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-sm border-0">

                <div class="card-body text-center">

                    <h6 class="text-muted">
                        Inactive Users
                    </h6>

                    <h2 class="fw-bold text-danger">
                        @Model.InactiveUsers
                    </h2>

                </div>

            </div>

        </div>

    </div>

    <!-- Search -->

    <div class="card shadow-sm border-0 mb-4">

        <div class="card-body">

            <form method="get">

                <div class="row">

                    <div class="col-md-10">

                        <input name="search"
                               value="@Model.Search"
                               class="form-control"
                               placeholder="Search Username..." />

                    </div>

                    <div class="col-md-2 d-grid">

                        <button class="btn btn-primary">

                            <i class="bi bi-search"></i>

                            Search

                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>

    <!-- Table -->

    <div class="card shadow border-0">

        <div class="card-body table-responsive">

            <table class="table table-hover align-middle">

                <thead class="table-dark">

                    <tr>

                        <th>Username</th>
                        <th>Employee Code</th>
                        <th>Employee Name</th>
                        <th>Department</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Last Login</th>
                        <th class="text-center">Actions</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model.Users.Any())
                    {
                        foreach (var user in Model.Users)
                        {
                            <tr>

                                <td class="fw-semibold">
                                    @user.Username
                                </td>
                                <td>

                                    @if (user.Employee != null)
                                    {
                                        <span class="badge bg-dark">

                                            @user.Employee.EmployeeCode

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">

                                            Not Linked

                                        </span>
                                    }

                                </td>
                                <td>

                                    @if (user.Employee != null)
                                    {
                                        @user.Employee.FirstName @user.Employee.LastName
                                    }
                                    else
                                    {
                                        <span class="text-muted">

                                            Not Linked

                                        </span>
                                    }

                                </td>
                                <td>

                                    @if (user.Employee?.Department != null)
                                    {
                                        <span class="badge bg-primary">

                                            @user.Employee.Department.DepartmentName

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">

                                            -

                                        </span>
                                    }

                                </td>
                                    <td>

                                        @if (user.Employee?.Role != null)
                                        {
                                            <span class="badge bg-success">
                                                @user.Employee.Role.RoleName
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                N/A
                                            </span>
                                        }


                                <td>

                                    @if (user.IsActive)
                                    {
                                        <span class="badge bg-success">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            Inactive
                                        </span>
                                    }

                                </td>

                                <td>

                                    @if (user.LastLogin == null)
                                    {
                                        <span class="text-muted">

                                            Never Logged In

                                        </span>
                                    }
                                    else if (user.LastLogin.Value.Date == DateTime.Today)
                                    {
                                        <span class="badge bg-success">

                                            Today,
                                            @user.LastLogin.Value.ToString("hh:mm tt")

                                        </span>
                                    }
                                    else if (user.LastLogin.Value.Date == DateTime.Today.AddDays(-1))
                                    {
                                        <span class="badge bg-warning text-dark">

                                            Yesterday,
                                            @user.LastLogin.Value.ToString("hh:mm tt")

                                        </span>
                                    }
                                    else
                                    {
                                        <span>

                                            @user.LastLogin.Value.ToString("dd MMM yyyy")

                                        </span>
                                    }

                                </td>

                                <td class="text-center">
                                        @if (await PermissionService.HasPermissionAsync("User.ChangeStatus"))
                                        {
                                            <form asp-action="ChangeStatus"
                                                  asp-route-id="@user.AdminId"
                                                  method="post"
                                                  class="d-inline">

                                                @Html.AntiForgeryToken()

                                                <button type="submit"
                                                        class="btn btn-sm btn-secondary">

                                                    @if (user.IsActive)
                                                    {
                                                        <i class="bi bi-person-x"></i>
                                                        <span>Deactivate</span>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-person-check"></i>
                                                        <span>Activate</span>
                                                    }

                                                </button>

                                            </form>
                                        }

                                    @if (await PermissionService.HasPermissionAsync("User.Edit"))
                                    {
                                        <a asp-action="Edit"
                                           asp-route-id="@user.AdminId"
                                           class="btn btn-sm btn-warning">

                                            <i class="bi bi-pencil-square"></i>

                                        </a>
                                    }

                                    @if (await PermissionService.HasPermissionAsync("User.ResetPassword"))
                                    {
                                        <a asp-action="ResetPassword"
                                           asp-route-id="@user.AdminId"
                                           class="btn btn-sm btn-info text-white">

                                            <i class="bi bi-key-fill"></i>

                                        </a>
                                    }
                                    @if (await PermissionService.HasPermissionAsync("User.Delete"))
                                    {
                                        <a asp-action="Delete"
                                           asp-route-id="@user.AdminId"
                                           class="btn btn-sm btn-danger">

                                            <i class="bi bi-trash-fill"></i>

                                        </a>
                                    }


                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="5"
                                class="text-center text-muted">

                                No users found.

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
}
else
{
    <div class="alert alert-danger">
        You don't have permission to view users.
    </div>
}