@model EmployeeManagementSystem.ViewModels.CreateUserViewModel

@{
    ViewData["Title"] = "Create User";
}

<div class="container py-4">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-primary text-white py-3">

            <h2 class="mb-0">
                <i class="bi bi-person-plus-fill"></i>
                Create User
            </h2>

        </div>

        <div class="card-body p-4">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-4"></div>

                <div class="row">
                    <div class="col-md-6 mb-4" id="employeeSection">

                        <label asp-for="EmployeeId" class="form-label">

                            Employee

                        </label>

                        <select asp-for="EmployeeId"
                                asp-items="Model.Employees"
                                class="form-select"
                                id="EmployeeId">

                            <option value="">

                                -- Select Employee --

                            </option>

                        </select>

                        <span asp-validation-for="EmployeeId"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6 mb-4">

                        <label asp-for="Username"
                               class="form-label fw-semibold"></label>

                        <input asp-for="Username"
                               class="form-control" />

                        <span asp-validation-for="Username"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6 mb-4">

                        <label asp-for="RoleId"
                               class="form-label fw-semibold">
                            Role
                        </label>

                        <select asp-for="RoleId"
                                class="form-select">

                            <option value="">-- Select Role --</option>

                            @foreach (var role in Model.Roles)
                            {
                                <option value="@role.Value">
                                    @role.Text
                                </option>
                            }

                        </select>

                        <span asp-validation-for="RoleId"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="col-md-12 mb-4">

                        <div class="form-check">

                            <input asp-for="IsActive"
                                   class="form-check-input" />

                            <label asp-for="IsActive"
                                   class="form-check-label">
                                Active User
                            </label>

                        </div>

                    </div>

                </div>

                <hr />

                <div class="text-end">

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        ← Back

                    </a>

                    <button type="submit"
                            class="btn btn-primary">

                        <i class="bi bi-check-circle"></i>

                        Create User

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
    
}