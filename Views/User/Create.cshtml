@model EmployeeManagementSystem.ViewModels.CreateUserViewModel

@{
    ViewData["Title"] = "Create User";
}

<div class="container py-4">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-primary text-white py-3">

            <h2 class="mb-0">
                <i class="bi bi-person-plus-fill"></i>
                Create User
            </h2>

        </div>

        <div class="card-body p-4">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-4"></div>

                <div class="row">

                    <div class="col-md-6 mb-4">

                        <label asp-for="Username"
                               class="form-label fw-semibold"></label>

                        <input asp-for="Username"
                               class="form-control" />

                        <span asp-validation-for="Username"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6 mb-4">

                        <label asp-for="Role"
                               class="form-label fw-semibold"></label>

                        <select asp-for="Role"
                                class="form-select">

                            <option value="Admin">Admin</option>

                            <option value="HR">HR</option>

                            <option value="Manager">Manager</option>

                        </select>

                    </div>

                    <div class="col-md-6 mb-4">

                        <label asp-for="Password"
                               class="form-label fw-semibold"></label>

                        <input asp-for="Password"
                               type="password"
                               class="form-control" />

                        <span asp-validation-for="Password"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6 mb-4">

                        <label asp-for="ConfirmPassword"
                               class="form-label fw-semibold"></label>

                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="form-control" />

                        <span asp-validation-for="ConfirmPassword"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-12 mb-4">

                        <div class="form-check">

                            <input asp-for="IsActive"
                                   class="form-check-input" />

                            <label asp-for="IsActive"
                                   class="form-check-label">
                                Active User
                            </label>

                        </div>

                    </div>

                </div>

                <hr />

                <div class="text-end">

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        ← Back

                    </a>

                    <button type="submit"
                            class="btn btn-primary">

                        <i class="bi bi-check-circle"></i>

                        Create User

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}