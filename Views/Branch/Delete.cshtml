@model EmployeeManagementSystem.ViewModels.BranchViewModel

@{
    ViewData["Title"] = "Delete Branch";
}

<div class="container-fluid mt-4">

    <div class="card shadow-lg border-0">

        <div class="card-header bg-danger text-white">

            <h3 class="mb-0">
                <i class="fas fa-trash-alt"></i>
                Delete Branch
            </h3>

        </div>

        <div class="card-body">

            <div class="alert alert-warning">

                <h5>
                    <i class="fas fa-exclamation-triangle"></i>
                    Are you sure you want to delete this branch?
                </h5>

                <p class="mb-0">
                    This action cannot be undone.
                </p>

            </div>

            <table class="table table-bordered">

                <tr>
                    <th width="220">Branch Code</th>
                    <td>@Model.BranchCode</td>
                </tr>

                <tr>
                    <th>Branch Name</th>
                    <td>@Model.BranchName</td>
                </tr>

                <tr>
                    <th>City</th>
                    <td>@Model.City</td>
                </tr>

                <tr>
                    <th>State</th>
                    <td>@Model.State</td>
                </tr>

                <tr>
                    <th>Country</th>
                    <td>@Model.Country</td>
                </tr>

                <tr>
                    <th>Total Employees</th>
                    <td>

                        <span class="badge bg-primary">

                            @Model.EmployeeCount

                        </span>

                    </td>
                </tr>

            </table>

            @if (Model.EmployeeCount > 0)
            {
                <div class="alert alert-danger">

                    <i class="fas fa-times-circle"></i>

                    This branch contains employees.

                    Please transfer employees before deleting it.

                </div>
            }

            <form asp-action="Delete"
                  method="post">

                <input asp-for="BranchId" type="hidden" />

                <div class="text-end">

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        <i class="fas fa-arrow-left"></i>

                        Back

                    </a>

                    @if (Model.EmployeeCount == 0)
                    {
                        <button type="submit"
                                class="btn btn-danger">

                            <i class="fas fa-trash"></i>

                            Delete Branch

                        </button>
                    }

                </div>

            </form>

        </div>

    </div>

</div>