@{
    ViewData["Title"] = "About Us";
}



<div class="about-page">





    <!-- =========================================
            ABOUT HERO SECTION
    ========================================== -->


    <section class="about-hero">



        <div class="about-hero-content">



            <span class="about-badge">


                <i class="bi bi-building-check"></i>


                About EMS Pro


            </span>





            <h1>


                Simplifying Employee Management
                Through Digital Solutions


            </h1>





            <p>


                EMS Pro is a complete employee management
                platform designed to help organizations
                manage employees, departments, reports,
                and workforce operations efficiently.



            </p>






            <div class="about-buttons">



                <a asp-controller="Account"
                   asp-action="Login"
                   class="btn btn-primary">



                    <i class="bi bi-rocket-takeoff me-2"></i>


                    Get Started



                </a>





                <a asp-controller="Home"
                   asp-action="Features"
                   class="btn btn-outline-primary">



                    Explore Features



                </a>




            </div>




        </div>






        <div class="about-hero-icon">



            <i class="bi bi-people-fill"></i>



        </div>




    </section>








    <!-- =========================================
            INTRODUCTION SECTION
    ========================================== -->


    <section class="about-intro">





        <div class="about-intro-card">



            <div class="intro-icon">


                <i class="bi bi-lightbulb-fill"></i>


            </div>





            <div>


                <h2>


                    Our Purpose


                </h2>




                <p>


                    The Employee Management System is built
                    to simplify HR operations by providing
                    a centralized platform where organizations
                    can maintain employee records, monitor
                    activities, generate reports and improve
                    productivity.



                </p>



            </div>




        </div>





    </section>
    <!-- =========================================
            MISSION SECTION
    ========================================== -->


    <section class="about-mission">



        <div class="about-section-header">


            <span>

                Our Mission

            </span>



            <h2>

                Building Better Workforce Management

            </h2>



            <p>

                Helping organizations manage employees
                efficiently with simple and powerful tools.

            </p>


        </div>







        <div class="mission-grid">





            <!-- ORGANIZATION -->


            <div class="mission-card">


                <div class="mission-icon blue">


                    <i class="bi bi-diagram-3-fill"></i>


                </div>



                <h4>

                    Organized Management

                </h4>



                <p>

                    Maintain employee information,
                    departments and records in a
                    structured system.

                </p>


            </div>








            <!-- PRODUCTIVITY -->


            <div class="mission-card">


                <div class="mission-icon green">


                    <i class="bi bi-graph-up-arrow"></i>


                </div>



                <h4>

                    Improve Productivity

                </h4>



                <p>

                    Reduce manual work and improve
                    daily HR operations with automation.

                </p>


            </div>








            <!-- SECURITY -->


            <div class="mission-card">


                <div class="mission-icon purple">


                    <i class="bi bi-shield-lock-fill"></i>


                </div>



                <h4>

                    Secure Platform

                </h4>



                <p>

                    Protect important employee data
                    with secure authentication and access.

                </p>


            </div>






        </div>



    </section>








    <!-- =========================================
            BENEFITS SECTION
    ========================================== -->


    <section class="about-benefits">



        <div class="benefits-card">



            <div class="benefits-content">


                <h2>

                    Why Choose EMS Pro?

                </h2>



                <p>

                    EMS Pro provides everything required
                    for efficient employee management
                    in a single centralized platform.

                </p>




                <ul>


                    <li>

                        <i class="bi bi-check-circle-fill"></i>

                        Easy employee record management

                    </li>




                    <li>

                        <i class="bi bi-check-circle-fill"></i>

                        Department and organization control

                    </li>





                    <li>

                        <i class="bi bi-check-circle-fill"></i>

                        Professional reports and analytics

                    </li>





                    <li>

                        <i class="bi bi-check-circle-fill"></i>

                        Secure authentication system

                    </li>




                </ul>



            </div>




            <div class="benefits-image">


                <i class="bi bi-person-workspace"></i>


            </div>




        </div>



    </section>
    <!-- =========================================
            TECHNOLOGY SECTION
    ========================================== -->


    <section class="about-technology">



        <div class="about-section-header">


            <span>

                Technology Stack

            </span>



            <h2>

                Built With Modern Technologies

            </h2>



            <p>

                EMS Pro is developed using reliable
                and scalable technologies.

            </p>


        </div>





        <div class="technology-grid">





            <div class="technology-card">


                <i class="bi bi-code-slash"></i>


                <h4>

                    ASP.NET Core MVC

                </h4>


                <p>

                    Backend framework for building
                    secure and scalable applications.

                </p>


            </div>







            <div class="technology-card">


                <i class="bi bi-database-fill"></i>


                <h4>

                    SQL Server

                </h4>


                <p>

                    Reliable database management
                    for employee information.

                </p>


            </div>







            <div class="technology-card">


                <i class="bi bi-bootstrap-fill"></i>


                <h4>

                    Bootstrap

                </h4>


                <p>

                    Responsive and modern user
                    interface design.

                </p>


            </div>







            <div class="technology-card">


                <i class="bi bi-file-earmark-bar-graph"></i>


                <h4>

                    Chart Analytics

                </h4>


                <p>

                    Visual dashboards and workforce
                    insights.

                </p>


            </div>




        </div>



    </section>








    <!-- =========================================
            FINAL CTA SECTION
    ========================================== -->


    <section class="about-cta">



        <div>



            <h2>

                Ready To Transform Employee Management?

            </h2>



            <p>

                Start using EMS Pro and experience
                simple, secure and efficient workforce
                management.

            </p>




            <a asp-controller="Account"
               asp-action="Login"
               class="btn btn-primary">


                <i class="bi bi-arrow-right-circle me-2"></i>


                Get Started


            </a>



        </div>



    </section>





</div>