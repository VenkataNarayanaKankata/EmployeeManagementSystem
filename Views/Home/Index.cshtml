@{
    ViewData["Title"] = "Employee Management System";
}

<div class="container-fluid p-0">

    <!-- Hero Section -->
    <section class="hero-section bg-primary text-white text-center py-5">

        <div class="container">

            <h1 class="display-4 fw-bold">
                Employee Management System
            </h1>

            <p class="lead mt-3">
                Manage employees, departments and HR operations
                with a secure ASP.NET Core MVC application.
            </p>

            <a asp-controller="Account"
               asp-action="Login"
               class="btn btn-light btn-lg mt-4 px-5">
                🔐 Admin Login
            </a>

        </div>

    </section>

    <!-- Features -->
    <section class="container py-5">

        <div class="text-center mb-5">

            <h2>Our Features</h2>

            <p class="text-muted">
                Everything required for managing employees efficiently.
            </p>

        </div>

        <div class="row">

            <div class="col-md-4 mb-4">

                <div class="card shadow h-100">

                    <div class="card-body text-center">

                        <h1>👨‍💼</h1>

                        <h4>Employee Management</h4>

                        <p class="text-muted">
                            Add, edit, delete and manage employee records with profile photos.
                        </p>

                    </div>

                </div>

            </div>

            <div class="col-md-4 mb-4">

                <div class="card shadow h-100">

                    <div class="card-body text-center">

                        <h1>🏢</h1>

                        <h4>Department Management</h4>

                        <p class="text-muted">
                            Organize employees by department with easy administration.
                        </p>

                    </div>

                </div>

            </div>

            <div class="col-md-4 mb-4">

                <div class="card shadow h-100">

                    <div class="card-body text-center">

                        <h1>🔐</h1>

                        <h4>Secure Authentication</h4>

                        <p class="text-muted">
                            Cookie authentication with BCrypt password hashing.
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </section>

    <!-- Why Choose -->
    <section class="bg-light py-5">

        <div class="container">

            <div class="text-center">

                <h2>Why Choose Our System?</h2>

                <p class="text-muted mb-5">
                    A modern Employee Management solution built with ASP.NET Core MVC.
                </p>

            </div>

            <div class="row text-center">

                <div class="col-md-3">

                    <h3>✔</h3>

                    <h5>Employee Records</h5>

                </div>

                <div class="col-md-3">

                    <h3>✔</h3>

                    <h5>Department Management</h5>

                </div>

                <div class="col-md-3">

                    <h3>✔</h3>

                    <h5>Reports & Analytics</h5>

                </div>

                <div class="col-md-3">

                    <h3>✔</h3>

                    <h5>Secure Login</h5>

                </div>

            </div>

        </div>

    </section>

</div>  