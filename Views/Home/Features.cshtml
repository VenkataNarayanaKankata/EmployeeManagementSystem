@{
    ViewData["Title"] = "Features";
}


<div class="features-page">


    <!-- =========================================
            FEATURES HERO
    ========================================== -->


    <section class="features-hero">


        <div class="features-hero-content">


            <span class="features-badge">

                <i class="bi bi-stars"></i>

                Powerful Features

            </span>




            <h1>

                Everything You Need
                <br />

                To Manage Your Workforce

            </h1>




            <p>

                EMS Pro provides complete employee management
                solutions to organize employees, departments,
                reports and business operations efficiently.

            </p>




            <div class="features-buttons">


                <a asp-controller="Account"
                   asp-action="Login"
                   class="btn btn-primary">


                    <i class="bi bi-box-arrow-in-right me-2"></i>

                    Get Started


                </a>



                <a asp-controller="Home"
                   asp-action="About"
                   class="btn btn-outline-primary">


                    Learn More


                </a>


            </div>



        </div>





        <div class="features-hero-icon">


            <i class="bi bi-grid-1x2-fill"></i>


        </div>



    </section>





    <!-- =========================================
            FEATURE TITLE
    ========================================== -->


    <section class="features-section">



        <div class="features-heading">


            <span>

                EMS Capabilities

            </span>



            <h2>

                Designed For Modern Organizations

            </h2>



            <p>

                Powerful modules to simplify daily
                employee management activities.

            </p>


        </div>
        <!-- =========================================
                FEATURE CARDS
        ========================================== -->


        <div class="features-grid">





            <!-- Employee Management -->


            <div class="feature-card">


                <div class="feature-icon blue">


                    <i class="bi bi-people-fill"></i>


                </div>



                <h4>

                    Employee Management

                </h4>



                <p>

                    Manage employee profiles, personal details,
                    salaries, joining information and records
                    from one centralized system.

                </p>



            </div>








            <!-- Department Management -->


            <div class="feature-card">


                <div class="feature-icon green">


                    <i class="bi bi-building-fill"></i>


                </div>



                <h4>

                    Department Management

                </h4>



                <p>

                    Organize employees into departments
                    and maintain a structured company
                    hierarchy.

                </p>



            </div>








            <!-- Reports -->


            <div class="feature-card">


                <div class="feature-icon orange">


                    <i class="bi bi-bar-chart-fill"></i>


                </div>



                <h4>

                    Reports & Analytics

                </h4>



                <p>

                    Generate employee reports, salary
                    analysis and workforce insights
                    easily.

                </p>



            </div>








            <!-- Security -->


            <div class="feature-card">


                <div class="feature-icon red">


                    <i class="bi bi-shield-check"></i>


                </div>



                <h4>

                    Secure Authentication

                </h4>



                <p>

                    Protect application data with secure
                    login authentication and controlled
                    access.

                </p>



            </div>








            <!-- Email -->


            <div class="feature-card">


                <div class="feature-icon purple">


                    <i class="bi bi-envelope-check"></i>


                </div>



                <h4>

                    Email Notifications

                </h4>



                <p>

                    Send automated notifications and
                    important updates to employees.

                </p>



            </div>








            <!-- Activity -->


            <div class="feature-card">


                <div class="feature-icon cyan">


                    <i class="bi bi-clock-history"></i>


                </div>



                <h4>

                    Activity Tracking

                </h4>



                <p>

                    Monitor user activities and maintain
                    complete system history.

                </p>



            </div>





        </div>

        



    </section>





    <!-- =========================================
            CALL TO ACTION
    ========================================== -->


    <section class="features-cta">


        <div class="cta-content">



            <h2>

                Ready To Manage Your Workforce Better?

            </h2>




            <p>

                Start using EMS Pro and simplify
                employee management with powerful
                digital solutions.

            </p>




            <a asp-controller="Account"
               asp-action="Login"
               class="btn btn-primary">


                <i class="bi bi-arrow-right-circle me-2"></i>


                Get Started


            </a>



        </div>



    </section>





</div>
